// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Page Snapshots > dashboard page should match snapshot 1`] = `"<div class="dashboard"><div class="page-header"><div class="header-text"><h2 class="page-title">dashboard.title</h2><p class="page-subtitle">dashboard.subtitle</p></div><div class="header-actions"><div class="ws-status"><span class="ws-dot"></span><span class="ws-label">dashboard.realtimeConnecting</span></div><button class="btn-refresh">common.refresh</button></div></div><div class="summary-grid"><div class="summary-card card-total"><div class="card-icon">◈</div><div class="card-content"><span class="card-label">dashboard.servicesOverview</span><span class="card-value">0</span></div></div><div class="summary-card card-healthy"><div class="card-icon">◉</div><div class="card-content"><span class="card-label">dashboard.healthyServices</span><span class="card-value">0</span></div></div><div class="summary-card card-down"><div class="card-icon">⛔</div><div class="card-content"><span class="card-label">dashboard.downServices</span><span class="card-value">0</span></div></div><div class="summary-card card-degraded"><div class="card-icon">⚠</div><div class="card-content"><span class="card-label">dashboard.degradedServices</span><span class="card-value">0</span></div></div><div class="summary-card card-incidents"><div class="card-icon">⚡</div><div class="card-content"><span class="card-label">dashboard.openIncidents</span><span class="card-value">0</span></div></div><div class="summary-card card-alerts"><div class="card-icon">🔔</div><div class="card-content"><span class="card-label">dashboard.activeAlerts</span><span class="card-value">0</span></div></div></div><div class="dashboard-body"><section class="panel panel-feed"><div class="panel-header"><h3 class="panel-title">dashboard.systemHealth</h3></div><div class="event-list"><div class="empty-state"><span class="empty-icon">✓</span><span>dashboard.noRecentEvents</span></div></div></section></div></div>"`;

exports[`Page Snapshots > incidents page should match snapshot 1`] = `"<div class="incidents-page"><div class="page-header"><div class="page-header-left"><h2 class="page-title">incidents.title</h2><span class="page-count">0 common.total</span></div><button class="refresh-btn">↻</button></div><div class="filter-bar"><div class="filter-group"><button class="filter-btn active" data-filter="all">common.all</button><button class="filter-btn" data-filter="open">incidents.status.open</button><button class="filter-btn" data-filter="acknowledged">incidents.status.acknowledged</button><button class="filter-btn" data-filter="resolved">incidents.status.resolved</button></div></div><div class="empty-state"><span class="empty-icon">✓</span><p>incidents.noIncidents</p></div></div>"`;

exports[`Page Snapshots > login page should match snapshot 1`] = `"<div class="login-page"><div class="login-card"><div class="card-header"><div class="logo"><span class="logo-text">Vais Monitor</span></div><h1 class="card-title">auth.loginTitle</h1><p class="card-subtitle">auth.loginSubtitle</p></div><form class="auth-form"><div class="form-group"><label for="email">auth.email</label><input id="email" type="email" class="form-input"></div><div class="form-group"><label for="password">auth.password</label><div class="input-wrapper"><input id="password" type="password" class="form-input"><button type="button" class="toggle-password"></button></div></div><button type="submit" class="btn btn-primary">auth.loginBtn</button></form><div class="divider"><span class="divider-text">or</span></div><button type="button" class="btn btn-github">auth.githubLogin</button><p class="auth-link">auth.noAccount<a href="/auth/register" class="link">auth.goToRegister</a></p></div></div>"`;

exports[`Page Snapshots > register page should match snapshot 1`] = `"<div class="register-page"><div class="register-card"><div class="card-header"><h1 class="card-title">auth.registerTitle</h1><p class="card-subtitle">auth.registerSubtitle</p></div><form class="auth-form"><div class="form-group"><label for="name">auth.name</label><input id="name" type="text" class="form-input"></div><div class="form-group"><label for="email">auth.email</label><input id="email" type="email" class="form-input"></div><div class="form-group"><label for="password">auth.password</label><input id="password" type="password" class="form-input"></div><div class="form-group"><label for="confirm-password">auth.confirmPassword</label><input id="confirm-password" type="password" class="form-input"></div><button type="submit" class="btn btn-primary">auth.registerBtn</button></form><button type="button" class="btn btn-github">auth.githubLogin</button></div></div>"`;

exports[`Page Snapshots > services page should match snapshot 1`] = `"<div class="services-page"><div class="page-header"><div class="header-left"><h1 class="page-title">services.title</h1><p class="page-subtitle">0 common.total</p></div><div class="header-right"><div class="view-toggle"><button class="view-btn active">≡</button><button class="view-btn">⊞</button></div><button class="btn btn-primary">services.addService</button></div></div><div class="filter-bar"><div class="search-box"><input type="search" class="search-input" placeholder="common.search"></div></div><div class="table-container"><table class="data-table"><thead><tr><th>services.name</th><th>common.status</th><th>services.url</th><th>common.actions</th></tr></thead><tbody></tbody></table></div></div>"`;

exports[`Page Snapshots > settings page should match snapshot 1`] = `"<div class="settings-page"><div class="page-header"><div class="header-title"><h2>settings.title</h2><p class="header-subtitle">settings.subtitle</p></div><div class="settings-subnav"><a href="/settings/team" class="subnav-link"><span class="subnav-icon">◈</span><span>settings.teamManagement</span></a><a href="/settings/backup" class="subnav-link"><span class="subnav-icon">▣</span><span>settings.backup</span></a></div></div><div class="tab-nav" role="tablist"><button class="tab-btn active" role="tab" aria-selected="true"><span class="tab-icon">⚙</span><span>settings.general</span></button><button class="tab-btn" role="tab" aria-selected="false"><span class="tab-icon">🔔</span><span>settings.notifications</span></button><button class="tab-btn" role="tab" aria-selected="false"><span class="tab-icon">⬡</span><span>settings.integrations</span></button><button class="tab-btn" role="tab" aria-selected="false"><span class="tab-icon">🔒</span><span>settings.security</span></button></div><div class="tab-content" data-active-tab="general"></div></div>"`;
