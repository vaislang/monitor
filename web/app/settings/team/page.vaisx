}

@media (max-width: 640px) {
  .member-header,
  .member-row {
    grid-template-columns: 1fr;
    gap: 4px;
  }

  .member-header {
    display: none;
  }

  .invite-header,
  .invite-row {
    grid-template-columns: 1fr;
    gap: 4px;
  }

  .invite-header {
    display: none;
  }
}
