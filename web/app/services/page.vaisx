  color: var(--color-text-primary);
}

.delete-target-name {
  font-size: 15px;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* 반응형 */
@media (max-width: 680px) {
  .page-header {
    flex-direction: column;
    align-items: stretch;
  }

  .header-right {
    justify-content: flex-end;
  }

  .filter-bar {
