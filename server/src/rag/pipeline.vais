
# ============================================================================
# RAG 파이프라인
# 질의 → 임베딩 → 하이브리드 검색 → 컨텍스트 조합 → 응답 생성
# 에이전트 메모리: agent_memories 테이블 기반 대화 컨텍스트 저장/조회
# ============================================================================

# ============================================================================
# 테이블 초기화
# ============================================================================

# RAG 관련 테이블 초기화 (agent_memories, rag_documents)
F init_rag_tables() {
    # 에이전트 메모리 테이블
    db_execute(
        "CREATE TABLE IF NOT EXISTS agent_memories (" +
        "  id INTEGER PRIMARY KEY," +
        "  session_id TEXT NOT NULL," +
        "  role TEXT NOT NULL," +
        "  content TEXT NOT NULL," +
        "  created_at INTEGER NOT NULL" +
        ")"
    )

    # RAG 문서 저장 테이블
    db_execute(
        "CREATE TABLE IF NOT EXISTS rag_documents (" +
        "  id INTEGER PRIMARY KEY," +
        "  title TEXT NOT NULL," +
        "  content TEXT NOT NULL," +
        "  source_type TEXT NOT NULL DEFAULT 'document'," +
        "  chunk_index INTEGER NOT NULL DEFAULT 0," +
        "  created_at INTEGER NOT NULL" +
        ")"
    )

    # agent_memories 인덱스
    db_execute("CREATE INDEX IF NOT EXISTS idx_agent_memories_session ON agent_memories(session_id)")
    db_execute("CREATE INDEX IF NOT EXISTS idx_agent_memories_created ON agent_memories(created_at)")

    # rag_documents 풀텍스트 인덱스
    db_execute("CREATE FULLTEXT INDEX IF NOT EXISTS idx_rag_docs_ft ON rag_documents(content)")
    db_execute("CREATE FULLTEXT INDEX IF NOT EXISTS idx_rag_docs_title_ft ON rag_documents(title)")

    # rag_documents 일반 인덱스
    db_execute("CREATE INDEX IF NOT EXISTS idx_rag_docs_source ON rag_documents(source_type)")
}

# ============================================================================
# 내부 헬퍼: RRF(Reciprocal Rank Fusion) 점수 계산
# rank: 1부터 시작하는 순위, k: 상수 (기본 60)
# rrf_score = 1 / (k + rank)
# ============================================================================

F rrf_score(rank: i64, k: i64) -> f64 {
    safe_k := I k < 1 { 60 } EL { k }
    1.0 / (str_to_f64(i64_to_str(safe_k + rank)))
}

# ============================================================================
# 내부 헬퍼: JSON array of {doc_id, rrf_score} 에서 doc_id 위치 탐색
# doc_ids_json: JSON array string of i64 (문자열 형태)
# 반환: 인덱스 (-1이면 없음)
# ============================================================================

F find_doc_index(doc_ids_json: str, target_id: i64) -> i64 {
    len := count_json_array(doc_ids_json)
    i := 0
    LW i < len {
        val_str := json_get(doc_ids_json, i64_to_str(i))
        I str_to_i64(val_str) == target_id {
            R i
        }
        i = i + 1
    }
    -1
}

# ============================================================================
# 내부 헬퍼: 벡터 검색 결과 파싱 — source_id 목록 추출 (top_k개)
# search_similar 결과는 JSON array: [{id, log_id/incident_id/service_id, score}, ...]
# 반환: str (JSON array string of i64)
# ============================================================================

F parse_vector_result_ids(results_json: str, source_type: str, top_k: i64) -> str {
    ids := "[]"

    I str_len(results_json) == 0 || results_json == "[]" {
        R ids
    }

    # json_get으로 인덱스 기반 메모리 내 순회 — DB 호출 없음
    i := 0
    LW i < top_k {
        row_str := json_get(results_json, i64_to_str(i))
        I str_len(row_str) == 0 {
            i = top_k # 더 이상 항목 없음 — 루프 종료
        } EL {
            src_id_str := I source_type == "log" {
                json_get(row_str, "log_id")
            } EL {
                I source_type == "incident" {
                    json_get(row_str, "incident_id")
                } EL {
                    json_get(row_str, "service_id")
                }
            }
            I str_len(src_id_str) > 0 {
                I ids == "[]" {
                    ids = "[" + src_id_str + "]"
                } EL {
                    ids = str_slice(ids, 0, str_len(ids) - 1) + "," + src_id_str + "]"
                }
            }
            i = i + 1
        }
    }

    ids
}

# ============================================================================
# hybrid_search — 벡터 유사 검색 + Full-Text BM25 검색 → RRF 합산
# query: 질의 텍스트
# query_vector: 임베딩 벡터 JSON 배열 문자열
# source_type: "log" / "incident" / "metric" / "document"
# top_k: 최종 반환 결과 수
# 반환: JSON array string [{doc_id, rrf_score, rank}, ...]
# ============================================================================

F hybrid_search(query: str, query_vector: str, source_type: str, top_k: i64) -> str {
    safe_k := I top_k < 1 { 10 } EL { top_k }
    safe_k := I safe_k > 100 { 100 } EL { safe_k }

    # --- 1. 벡터 유사 검색 (코사인/L2 거리 기반) ---
    vector_results_json := search_similar(query_vector, source_type, safe_k)

    # --- 2. Full-Text BM25 검색 ---
    # source_type에 따라 적절한 테이블/컬럼에서 BM25 검색
    # FTS 안전 이스케이프: 백슬래시, single-quote, FTS 연산자 문자 제거
    safe_fts_query := str_replace(query, "\\", "\\\\")
    safe_fts_query := str_replace(safe_fts_query, "'", "''")
    safe_fts_query := str_replace(safe_fts_query, "\"", "")
    safe_fts_query := str_replace(safe_fts_query, "*", "")
    safe_fts_query := str_replace(safe_fts_query, "(", "")
    safe_fts_query := str_replace(safe_fts_query, ")", "")
    safe_query := safe_fts_query
    ft_results_json := I source_type == "log" {
        db_query(
            "SELECT id, log_id as doc_id FROM log_vectors lv " +
            "JOIN logs l ON l.id = lv.log_id " +
            "WHERE FULLTEXT_MATCH(l.message, '" + safe_query + "') USING BM25 " +
            "ORDER BY FULLTEXT_SCORE DESC " +
            "LIMIT " + i64_to_str(safe_k)
        )
    } EL {
        I source_type == "incident" {
            db_query(
                "SELECT id, incident_id as doc_id FROM incident_vectors iv " +
                "JOIN incidents i ON i.id = iv.incident_id " +
                "WHERE FULLTEXT_MATCH(i.title, '" + safe_query + "') USING BM25 " +
                "OR FULLTEXT_MATCH(i.description, '" + safe_query + "') USING BM25 " +
                "ORDER BY FULLTEXT_SCORE DESC " +
                "LIMIT " + i64_to_str(safe_k)
            )
        } EL {
            # document / metric: rag_documents 테이블 검색
            db_query(
                "SELECT id as doc_id FROM rag_documents " +
                "WHERE FULLTEXT_MATCH(content, '" + safe_query + "') USING BM25 " +
                "ORDER BY FULLTEXT_SCORE DESC " +
                "LIMIT " + i64_to_str(safe_k)
            )
        }
    }

    # --- 3. RRF 합산 ---
    # doc_id별 rrf 점수를 누적하는 병렬 JSON 배열: doc_ids[i] ↔ rrf_scores[i]
    doc_ids := "[]"
    rrf_scores := "[]"

    # 벡터 검색 결과 RRF 점수 반영 (순위 1부터) — 메모리 내 json_get 순회
    vi := 0
    LW vi < safe_k {
        vrow_val := json_get(vector_results_json, i64_to_str(vi))
        I str_len(vrow_val) == 0 {
            vi = safe_k
        } EL {
            src_id_str := I source_type == "log" {
                json_get(vrow_val, "log_id")
            } EL {
                I source_type == "incident" {
                    json_get(vrow_val, "incident_id")
                } EL {
                    json_get(vrow_val, "service_id")
                }
            }
            I str_len(src_id_str) > 0 {
                src_id := str_to_i64(src_id_str)
                score := rrf_score(vi + 1, 60)
                pos := find_doc_index(doc_ids, src_id)
                I pos < 0 {
                    I doc_ids == "[]" {
                        doc_ids = "[" + src_id_str + "]"
                        rrf_scores = "[" + f64_to_str(score) + "]"
                    } EL {
                        doc_ids = str_slice(doc_ids, 0, str_len(doc_ids) - 1) + "," + src_id_str + "]"
                        rrf_scores = str_slice(rrf_scores, 0, str_len(rrf_scores) - 1) + "," + f64_to_str(score) + "]"
                    }
                } EL {
                    # 기존 score에 누적 — JSON set으로 업데이트
                    old_score := str_to_f64(json_get(rrf_scores, i64_to_str(pos)))
                    new_score := old_score + score
                    rrf_scores = json_set(rrf_scores, i64_to_str(pos), f64_to_str(new_score))
                }
            }
            vi = vi + 1
        }
    }

    # Full-Text 검색 결과 RRF 점수 반영 — 메모리 내 json_get 순회
    fi := 0
    LW fi < safe_k {
        frow_val := json_get(ft_results_json, i64_to_str(fi))
        I str_len(frow_val) == 0 {
            fi = safe_k
        } EL {
            doc_id_str := json_get(frow_val, "doc_id")
            I str_len(doc_id_str) > 0 {
                doc_id := str_to_i64(doc_id_str)
                score := rrf_score(fi + 1, 60)
                pos := find_doc_index(doc_ids, doc_id)
                I pos < 0 {
                    I doc_ids == "[]" {
                        doc_ids = "[" + doc_id_str + "]"
                        rrf_scores = "[" + f64_to_str(score) + "]"
                    } EL {
                        doc_ids = str_slice(doc_ids, 0, str_len(doc_ids) - 1) + "," + doc_id_str + "]"
                        rrf_scores = str_slice(rrf_scores, 0, str_len(rrf_scores) - 1) + "," + f64_to_str(score) + "]"
                    }
                } EL {
                    old_score := str_to_f64(json_get(rrf_scores, i64_to_str(pos)))
                    new_score := old_score + score
                    rrf_scores = json_set(rrf_scores, i64_to_str(pos), f64_to_str(new_score))
                }
            }
            fi = fi + 1
        }
    }

    # --- 4. RRF 점수 기준 정렬 (내림차순 선택 정렬) ---
    total_docs := count_json_array(doc_ids)
    si := 0
    LW si < total_docs {
        max_pos := si
        sj := si + 1
        LW sj < total_docs {
            I str_to_f64(json_get(rrf_scores, i64_to_str(sj))) > str_to_f64(json_get(rrf_scores, i64_to_str(max_pos))) {
                max_pos = sj
            }
            sj = sj + 1
        }
        # swap doc_ids[si] ↔ doc_ids[max_pos]
        I max_pos != si {
            tmp_id := json_get(doc_ids, i64_to_str(si))
            tmp_score := json_get(rrf_scores, i64_to_str(si))
            doc_ids = json_set(doc_ids, i64_to_str(si), json_get(doc_ids, i64_to_str(max_pos)))
            rrf_scores = json_set(rrf_scores, i64_to_str(si), json_get(rrf_scores, i64_to_str(max_pos)))
            doc_ids = json_set(doc_ids, i64_to_str(max_pos), tmp_id)
            rrf_scores = json_set(rrf_scores, i64_to_str(max_pos), tmp_score)
        }
        si = si + 1
    }

    # --- 5. 결과 직렬화 (top_k개) ---
    out := "["
    limit := I total_docs < safe_k { total_docs } EL { safe_k }
    ri := 0
    LW ri < limit {
        item := "{}"
        item := json_set(item, "doc_id", json_get(doc_ids, i64_to_str(ri)))
        item := json_set(item, "rrf_score", json_get(rrf_scores, i64_to_str(ri)))
        item := json_set(item, "rank", i64_to_str(ri + 1))
        I ri > 0 {
            out = out + ","
        }
        out = out + item
        ri = ri + 1
    }
    out = out + "]"
    out
}

# ============================================================================
# store_memory — 대화 컨텍스트를 agent_memories 테이블에 저장
# session_id: 대화 세션 식별자
# role: "user" / "assistant" / "system"
# content: 메시지 내용
# 반환: 새 memory 행 ID (0이면 실패)
# ============================================================================

F store_memory(session_id: str, role: str, content: str) -> i64 {
    I str_len(session_id) == 0 {
        R 0
    }
    I str_len(content) == 0 {
        R 0
    }

    now_sec := current_time_ms() / 1000
    db_prepare("store_memory",
        "INSERT INTO agent_memories (session_id, role, content, created_at) VALUES (?, ?, ?, ?)")
    mem_params := "[]"
    mem_params := json_set(mem_params, "0", session_id)
    mem_params := json_set(mem_params, "1", role)
    mem_params := json_set(mem_params, "2", content)
    mem_params := json_set(mem_params, "3", i64_to_str(now_sec))
    db_execute_prepared("store_memory", mem_params)
}

# ============================================================================
# recall_memory — 세션의 대화 컨텍스트 조회
# session_id: 대화 세션 식별자
# limit: 최근 N개 메시지 (0이면 기본 20개)
# 반환: JSON array string [{id, session_id, role, content, created_at}, ...]
# ============================================================================

F recall_memory(session_id: str, limit: i64) -> str {
    I str_len(session_id) == 0 {
        R "[]"
    }

    safe_limit := I limit < 1 { 20 } EL { limit }
    safe_limit := I safe_limit > 200 { 200 } EL { safe_limit }

    safe_session_id := str_replace(session_id, "'", "''")
    db_query(
        "SELECT id, session_id, role, content, created_at " +
        "FROM agent_memories " +
        "WHERE session_id = '" + safe_session_id + "' " +
        "ORDER BY created_at ASC " +
        "LIMIT " + i64_to_str(safe_limit)
    )
}

# ============================================================================
# recall_memory_recent — 세션의 최근 대화 컨텍스트 조회 (최신순)
# 반환: JSON array string (최신 N개, 역순)
# ============================================================================

F recall_memory_recent(session_id: str, limit: i64) -> str {
    I str_len(session_id) == 0 {
        R "[]"
    }

    safe_limit := I limit < 1 { 20 } EL { limit }
    safe_limit := I safe_limit > 200 { 200 } EL { safe_limit }

    safe_session_id := str_replace(session_id, "'", "''")
    db_query(
        "SELECT id, session_id, role, content, created_at " +
        "FROM agent_memories " +
        "WHERE session_id = '" + safe_session_id + "' " +
        "ORDER BY created_at DESC " +
        "LIMIT " + i64_to_str(safe_limit)
    )
}

# ============================================================================
# delete_memory — 세션의 대화 메모리 전체 삭제
# 반환: 삭제된 행 수
# ============================================================================

F delete_memory(session_id: str) -> i64 {
    I str_len(session_id) == 0 {
        R 0
    }

    db_prepare("delete_memory",
        "DELETE FROM agent_memories WHERE session_id = ?")
    del_mem_params := "[]"
    del_mem_params := json_set(del_mem_params, "0", session_id)
    db_execute_prepared("delete_memory", del_mem_params)
}

# ============================================================================
# build_context — hybrid_search 결과로부터 컨텍스트 텍스트 조합
# search_results: hybrid_search 반환 JSON array
# source_type: 검색 대상 타입
# max_tokens: 최대 컨텍스트 길이 (0이면 무제한)
# 반환: 컨텍스트 문자열 (각 결과의 내용을 연결)
# ============================================================================

F build_context(search_results: str, source_type: str, max_tokens: i64) -> str {
    I str_len(search_results) == 0 || search_results == "[]" {
        R ""
    }

    context := ""
    total_len := 0
    i := 0

    LW true {
        # 메모리 내 json_get 순회 — DB 호출 없음
        row_val := json_get(search_results, i64_to_str(i))
        I str_len(row_val) == 0 {
            i = 999999 # 루프 종료
        } EL {
            doc_id := str_to_i64(json_get(row_val, "doc_id"))
            rank := json_get(row_val, "rank")

            # source_type별 내용 조회
            doc_content := I source_type == "log" {
                log_row := db_query(
                    "SELECT message, level, source FROM logs WHERE id = " + i64_to_str(doc_id) + " LIMIT 1"
                )
                "[LOG][" + json_get(log_row, "level") + "] " + json_get(log_row, "message")
            } EL {
                I source_type == "incident" {
                    inc_row := db_query(
                        "SELECT title, description, severity FROM incidents WHERE id = " + i64_to_str(doc_id) + " LIMIT 1"
                    )
                    "[INCIDENT][" + json_get(inc_row, "severity") + "] " + json_get(inc_row, "title") + ": " + json_get(inc_row, "description")
                } EL {
                    # document
                    doc_row := db_query(
                        "SELECT title, content FROM rag_documents WHERE id = " + i64_to_str(doc_id) + " LIMIT 1"
                    )
                    "[DOC] " + json_get(doc_row, "title") + ": " + json_get(doc_row, "content")
                }
            }

            entry := "[" + rank + "] " + doc_content + "\n"
            entry_len := str_len(entry)

            I max_tokens > 0 {
                I total_len + entry_len <= max_tokens {
                    context = context + entry
                    total_len = total_len + entry_len
                } EL {
                    i = 999999 # 최대 토큰 초과 — 루프 종료
                }
            } EL {
                context = context + entry
            }

            i = i + 1
        }
    }

    context
}

# ============================================================================
# rag_query — RAG 파이프라인 전체 흐름
# query: 사용자 질의 텍스트
# query_vector: 질의 임베딩 벡터 JSON 배열 문자열
# source_type: "log" / "incident" / "metric" / "document"
# session_id: 에이전트 메모리 세션 ID (빈 문자열이면 메모리 사용 안 함)
# top_k: 검색 결과 수
# 반환: {"query":..., "context":..., "memory":..., "search_results":..., "answer":...} JSON
# ============================================================================

F rag_query(query: str, query_vector: str, source_type: str, session_id: str, top_k: i64) -> str {
    safe_k := I top_k < 1 { 10 } EL { top_k }

    # --- 1. 하이브리드 검색 ---
    search_results := hybrid_search(query, query_vector, source_type, safe_k)

    # --- 2. 컨텍스트 조합 (최대 4096 토큰) ---
    context := build_context(search_results, source_type, 4096)

    # --- 3. 에이전트 메모리 조회 ---
    memory := I str_len(session_id) > 0 {
        recall_memory(session_id, 10)
    } EL {
        "[]"
    }

    # --- 4. 프롬프트 조합 ---
    memory_context := I str_len(session_id) > 0 && memory != "[]" {
        "[CONVERSATION HISTORY]\n" + memory + "\n\n"
    } EL {
        ""
    }

    prompt := memory_context +
        "[CONTEXT]\n" + context + "\n\n" +
        "[QUESTION]\n" + query

    # --- 5. 현재 질의를 메모리에 저장 ---
    I str_len(session_id) > 0 {
        stored := store_memory(session_id, "user", query)
    }

    # --- 6. 응답 생성 (실제 LLM 호출 위치) ---
    # 현재 구현에서는 컨텍스트 기반 응답을 직접 조합
    answer := I str_len(context) > 0 {
        "Based on the retrieved context for query '" + query + "': " + context
    } EL {
        "No relevant context found for query: " + query
    }

    # --- 7. 응답을 메모리에 저장 ---
    I str_len(session_id) > 0 {
        saved := store_memory(session_id, "assistant", answer)
    }

    # --- 8. 결과 직렬화 ---
    result := "{}"
    result := json_set(result, "query", query)
    result := json_set(result, "source_type", source_type)
    result := json_set(result, "context", context)
    result := json_set(result, "memory", memory)
    result := json_set(result, "search_results", search_results)
    result := json_set(result, "answer", answer)
    result := json_set(result, "session_id", session_id)
    result
}

# ============================================================================
# ingest_document — RAG용 문서 청킹 후 저장
# title: 문서 제목
# content: 문서 내용 (전체)
# source_type: 문서 타입 (기본 "document")
# config: 청킹 설정
# 반환: 저장된 청크 수
# ============================================================================

F ingest_document(title: str, content: str, source_type: str, config: &ChunkConfig) -> i64 {
    I str_len(content) == 0 {
        R 0
    }

    chunks := chunk_text(content, config)
    chunk_count_val := count_json_array(chunks)
    count := 0
    now_sec := current_time_ms() / 1000
    i := 0

    db_prepare("ingest_document_chunk",
        "INSERT INTO rag_documents (title, content, source_type, chunk_index, created_at) VALUES (?, ?, ?, ?, ?)")
    LW i < chunk_count_val {
        chunk_content := json_get(chunks, i64_to_str(i))
        doc_params := "[]"
        doc_params := json_set(doc_params, "0", title)
        doc_params := json_set(doc_params, "1", chunk_content)
        doc_params := json_set(doc_params, "2", source_type)
        doc_params := json_set(doc_params, "3", i64_to_str(i))
        doc_params := json_set(doc_params, "4", i64_to_str(now_sec))
        inserted := db_execute_prepared("ingest_document_chunk", doc_params)
        I inserted > 0 {
            count = count + 1
        }
        i = i + 1
    }

    count
}
