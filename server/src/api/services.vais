F handle_services(method: str, path: str, headers: str, body: str) -> str {
    path_parts := str_split(path, "?")
    path_only := json_get(path_parts, "0")
    query_params := json_get(path_parts, "1")
    I method == "DELETE" && str_contains(path_only, "/dependencies/") {
        segments := str_split(path_only, "/")
        service_id := str_to_i64(json_get(segments, "4"))
        dep_id := str_to_i64(json_get(segments, "6"))
        R handle_remove_dependency(headers, service_id, dep_id)
    }
    I method == "POST" && str_contains(path_only, "/dependencies") {
        segments := str_split(path_only, "/")
        service_id := str_to_i64(json_get(segments, "4"))
        R handle_add_dependency(headers, service_id, body)
    }
    I method == "GET" && str_contains(path_only, "/metrics") {
        segments := str_split(path_only, "/")
        service_id := str_to_i64(json_get(segments, "4"))
        R handle_service_metrics(headers, service_id, query_params)
    }
    I method == "GET" && str_contains(path_only, "/logs") {
        segments := str_split(path_only, "/")
        service_id := str_to_i64(json_get(segments, "4"))
        R handle_service_logs(headers, service_id, query_params)
    }
    I method == "GET" && (path_only == "/api/v1/services" || path_only == "/api/v1/services/") {
        R handle_list_services(headers, query_params)
    }
    I method == "POST" && (path_only == "/api/v1/services" || path_only == "/api/v1/services/") {
        R handle_create_service(headers, body)
    }
    I method == "GET" {
        segments := str_split(path_only, "/")
        service_id := str_to_i64(json_get(segments, "4"))
        R handle_get_service(headers, service_id)
    }
    I method == "PUT" {
        segments := str_split(path_only, "/")
        service_id := str_to_i64(json_get(segments, "4"))
        R handle_update_service(headers, service_id, body)
    }
    I method == "DELETE" {
        segments := str_split(path_only, "/")
        service_id := str_to_i64(json_get(segments, "4"))
        R handle_delete_service(headers, service_id)
    }
    error_response(404, "Services route not found")
}
