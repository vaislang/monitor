}
X F sleep_ms(ms: i64)

# Number conversion
F i64_to_str(n: i64) -> str {
    I n == 0 {
        R "0"
    }
    neg := false
    val := n
    I n < 0 {
        neg = true
        val = 0 - n
    }
    result := ""
    LW val > 0 {
        digit := val % 10
        I digit == 0 { result = "0" + result }
        EL I digit == 1 { result = "1" + result }
        EL I digit == 2 { result = "2" + result }
        EL I digit == 3 { result = "3" + result }
        EL I digit == 4 { result = "4" + result }
        EL I digit == 5 { result = "5" + result }
        EL I digit == 6 { result = "6" + result }
        EL I digit == 7 { result = "7" + result }
        EL I digit == 8 { result = "8" + result }
        EL { result = "9" + result }
        val = val / 10
    }
    I neg {
        result = "-" + result
    }
    R result
}

F f64_to_str(n: f64) -> str {
    int_part := n as i64
    int_str := i64_to_str(int_part)
    frac := n - (int_part as f64)
    I frac < 0.0 {
        frac = 0.0 - frac
    }
    frac1000 := (frac * 1000.0) as i64
    frac_str := i64_to_str(frac1000)
    flen := str_len(frac_str)
    LW flen < 3 {
        frac_str = "0" + frac_str
        flen = flen + 1
    }
    R int_str + "." + frac_str
}

# str_to_i64 — pure vais: parse decimal integer string
F str_to_i64(s: &str) -> i64 {
    slen := str_len(s)
    I slen == 0 {
        R 0
    }
    neg := false
    start := 0
    first := str_char_at(s, 0)
    I first == "-" {
        neg = true
        start = 1
    } EL I first == "+" {
        start = 1
    }
    result := 0
    i := start
    LW i < slen {
        ch := str_char_at(s, i)
        I ch == "0" { result = result * 10 + 0 }
        EL I ch == "1" { result = result * 10 + 1 }
        EL I ch == "2" { result = result * 10 + 2 }
        EL I ch == "3" { result = result * 10 + 3 }
        EL I ch == "4" { result = result * 10 + 4 }
        EL I ch == "5" { result = result * 10 + 5 }
        EL I ch == "6" { result = result * 10 + 6 }
        EL I ch == "7" { result = result * 10 + 7 }
        EL I ch == "8" { result = result * 10 + 8 }
        EL I ch == "9" { result = result * 10 + 9 }
        i = i + 1
    }
    I neg {
        R 0 - result
    }
    R result
}

# str_to_f64 — pure vais: parse decimal float string
F str_to_f64(s: &str) -> f64 {
    slen := str_len(s)
    I slen == 0 {
        R 0.0
    }
    neg := false
    start := 0
    first := str_char_at(s, 0)
    I first == "-" {
        neg = true
        start = 1
    } EL I first == "+" {
        start = 1
    }
    int_part := 0
    frac_part := 0
    frac_div := 1
    in_frac := false
    i := start
    LW i < slen {
        ch := str_char_at(s, i)
        I ch == "." {
            in_frac = true
        } EL I ch == "0" {
            I in_frac { frac_part = frac_part * 10 + 0; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 0 }
        } EL I ch == "1" {
            I in_frac { frac_part = frac_part * 10 + 1; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 1 }
        } EL I ch == "2" {
            I in_frac { frac_part = frac_part * 10 + 2; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 2 }
        } EL I ch == "3" {
            I in_frac { frac_part = frac_part * 10 + 3; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 3 }
        } EL I ch == "4" {
            I in_frac { frac_part = frac_part * 10 + 4; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 4 }
        } EL I ch == "5" {
            I in_frac { frac_part = frac_part * 10 + 5; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 5 }
        } EL I ch == "6" {
            I in_frac { frac_part = frac_part * 10 + 6; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 6 }
        } EL I ch == "7" {
            I in_frac { frac_part = frac_part * 10 + 7; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 7 }
        } EL I ch == "8" {
            I in_frac { frac_part = frac_part * 10 + 8; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 8 }
        } EL I ch == "9" {
            I in_frac { frac_part = frac_part * 10 + 9; frac_div = frac_div * 10 }
            EL { int_part = int_part * 10 + 9 }
        }
        i = i + 1
    }
    result := (int_part as f64) + ((frac_part as f64) / (frac_div as f64))
    I neg {
        R 0.0 - result
    }
    R result
}

# Math
# floor/ceil/sqrt — extern C math functions; require libm (-lm) at link time
X F floor(n: f64) -> f64
X F ceil(n: f64) -> f64
X F sqrt(n: f64) -> f64
# abs_f64 — pure vais implementation (no libm dependency)
F abs_f64(n: f64) -> f64 {
    I n < 0.0 {
        R 0.0 - n
    }
    R n
}
F abs_i64(n: i64) -> i64 {
    I n < 0 {
        R 0 - n
    }
    R n
}

