# vais-server runtime externals

# HTTP Server
X F server_listen(host: &str, port: i64)
X F server_stop()

# String utilities
# str_len — pure vais: counts bytes until null terminator via raw pointer arithmetic
X F __strlen(s: i64) -> i64
F str_len(s: &str) -> i64 {
    __strlen(s as i64)
}
# str_char_at — pure vais: loads one byte at offset and converts to single-char str
X F __load_byte(ptr: i64, idx: i64) -> i64
F str_char_at(s: &str, idx: i64) -> str {
    byte := __load_byte(s as i64, idx)
    I byte == 0 { R "" }
    I byte == 32 { R " " }
    I byte == 33 { R "!" }
    I byte == 34 { R "\"" }
    I byte == 35 { R "#" }
    I byte == 36 { R "$" }
    I byte == 37 { R "%" }
    I byte == 38 { R "&" }
    I byte == 39 { R "'" }
    I byte == 40 { R "(" }
    I byte == 41 { R ")" }
    I byte == 42 { R "*" }
    I byte == 43 { R "+" }
    I byte == 44 { R "," }
    I byte == 45 { R "-" }
    I byte == 46 { R "." }
    I byte == 47 { R "/" }
    I byte == 48 { R "0" }
    I byte == 49 { R "1" }
    I byte == 50 { R "2" }
    I byte == 51 { R "3" }
    I byte == 52 { R "4" }
    I byte == 53 { R "5" }
    I byte == 54 { R "6" }
    I byte == 55 { R "7" }
    I byte == 56 { R "8" }
    I byte == 57 { R "9" }
    I byte == 58 { R ":" }
    I byte == 59 { R ";" }
    I byte == 60 { R "<" }
    I byte == 61 { R "=" }
    I byte == 62 { R ">" }
    I byte == 63 { R "?" }
    I byte == 64 { R "@" }
    I byte == 65 { R "A" }
    I byte == 66 { R "B" }
    I byte == 67 { R "C" }
    I byte == 68 { R "D" }
    I byte == 69 { R "E" }
    I byte == 70 { R "F" }
    I byte == 71 { R "G" }
    I byte == 72 { R "H" }
    I byte == 73 { R "I" }
    I byte == 74 { R "J" }
    I byte == 75 { R "K" }
    I byte == 76 { R "L" }
    I byte == 77 { R "M" }
    I byte == 78 { R "N" }
    I byte == 79 { R "O" }
    I byte == 80 { R "P" }
    I byte == 81 { R "Q" }
    I byte == 82 { R "R" }
    I byte == 83 { R "S" }
    I byte == 84 { R "T" }
    I byte == 85 { R "U" }
    I byte == 86 { R "V" }
    I byte == 87 { R "W" }
    I byte == 88 { R "X" }
    I byte == 89 { R "Y" }
    I byte == 90 { R "Z" }
    I byte == 91 { R "[" }
    I byte == 92 { R "\\" }
    I byte == 93 { R "]" }
    I byte == 94 { R "^" }
    I byte == 95 { R "_" }
    I byte == 96 { R "`" }
    I byte == 97 { R "a" }
    I byte == 98 { R "b" }
    I byte == 99 { R "c" }
    I byte == 100 { R "d" }
    I byte == 101 { R "e" }
    I byte == 102 { R "f" }
    I byte == 103 { R "g" }
    I byte == 104 { R "h" }
    I byte == 105 { R "i" }
    I byte == 106 { R "j" }
    I byte == 107 { R "k" }
    I byte == 108 { R "l" }
    I byte == 109 { R "m" }
    I byte == 110 { R "n" }
    I byte == 111 { R "o" }
    I byte == 112 { R "p" }
    I byte == 113 { R "q" }
    I byte == 114 { R "r" }
    I byte == 115 { R "s" }
    I byte == 116 { R "t" }
    I byte == 117 { R "u" }
    I byte == 118 { R "v" }
    I byte == 119 { R "w" }
    I byte == 120 { R "x" }
    I byte == 121 { R "y" }
    I byte == 122 { R "z" }
    I byte == 123 { R "{" }
    I byte == 124 { R "|" }
    I byte == 125 { R "}" }
    I byte == 126 { R "~" }
    R "?"
}
# str_slice — pure vais: extracts substring [start, end)
F str_slice(s: &str, start: i64, end: i64) -> str {
    I start >= end {
        R ""
    }
    result := ""
    i := start
    LW i < end {
        result = result + str_char_at(s, i)
        i = i + 1
    }
    R result
}
F str_contains(s: &str, substr: &str) -> bool {
    slen := str_len(s)
    sublen := str_len(substr)
    I sublen == 0 {
        R true
    }
    i := 0
    LW i <= slen - sublen {
        chunk := str_slice(s, i, i + sublen)
        I chunk == substr {
            R true
        }
        i = i + 1
    }
    R false
}
# str_split — pure vais implementation (returns JSON array string)
# Usage: parts := str_split(s, delim)  → '["a","b","c"]'
# Access: json_get(parts, "0"), json_get(parts, "1"), etc.
F str_split(s: &str, delim: &str) -> str {
    result := "["
    start := 0
    dlen := str_len(delim)
    slen := str_len(s)
    count := 0
    i := 0
    LW i <= slen - dlen {
        chunk := str_slice(s, i, i + dlen)
        I chunk == delim {
            I count > 0 {
                result = result + ","
            }
            part := str_slice(s, start, i)
            result = result + "\"" + part + "\""
            count = count + 1
            start = i + dlen
            i = i + dlen
        } EL {
            i = i + 1
        }
    }
    # last segment
    I count > 0 {
        result = result + ","
    }
    last := str_slice(s, start, slen)
    result = result + "\"" + last + "\""
    result = result + "]"
    R result
}

# str_split_get — get item at index from str_split result
F str_split_get(split_result: &str, index: i64) -> str {
    json_get(split_result, i64_to_str(index))
}

# str_split_count — count items in str_split result
F str_split_count(split_result: &str) -> i64 {
    slen := str_len(split_result)
    I slen <= 2 {
        R 0
    }
    count := 1
    i := 0
    LW i < slen {
        ch := str_char_at(split_result, i)
        I ch == "," {
            count = count + 1
        }
        i = i + 1
    }
    R count
}
# count_json_array — count top-level elements in a JSON array string
# Handles nested objects/arrays by tracking depth
F count_json_array(arr: &str) -> i64 {
    slen := str_len(arr)
    I slen <= 2 {
        R 0
    }
    count := 0
    depth := 0
    i := 1
    LW i < slen - 1 {
        ch := str_char_at(arr, i)
        I ch == "{" || ch == "[" {
            depth = depth + 1
        } EL I ch == "}" || ch == "]" {
            depth = depth - 1
        } EL I ch == "," && depth == 0 {
            count = count + 1
        }
        i = i + 1
    }
    # if there was any content, count = commas + 1
    I slen > 2 {
        count = count + 1
    }
    R count
}

F str_starts_with(s: &str, prefix: &str) -> bool {
    plen := str_len(prefix)
    slen := str_len(s)
    I plen > slen {
        R false
    }
    chunk := str_slice(s, 0, plen)
    R chunk == prefix
}

F str_ends_with(s: &str, suffix: &str) -> bool {
    suflen := str_len(suffix)
    slen := str_len(s)
    I suflen > slen {
        R false
    }
    chunk := str_slice(s, slen - suflen, slen)
    R chunk == suffix
}

F str_trim(s: &str) -> str {
    slen := str_len(s)
    start := 0
    searching_start := true
    LW searching_start && start < slen {
        ch := str_char_at(s, start)
        I ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start = start + 1
        } EL {
            searching_start = false
        }
    }
    end := slen
    searching_end := true
    LW searching_end && end > start {
        ch := str_char_at(s, end - 1)
        I ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            end = end - 1
        } EL {
            searching_end = false
        }
    }
    R str_slice(s, start, end)
}

F str_to_lower(s: &str) -> str {
    slen := str_len(s)
    result := ""
    i := 0
    LW i < slen {
        ch := str_char_at(s, i)
        I ch == "A" { result = result + "a" }
        EL I ch == "B" { result = result + "b" }
        EL I ch == "C" { result = result + "c" }
        EL I ch == "D" { result = result + "d" }
        EL I ch == "E" { result = result + "e" }
        EL I ch == "F" { result = result + "f" }
        EL I ch == "G" { result = result + "g" }
        EL I ch == "H" { result = result + "h" }
        EL I ch == "I" { result = result + "i" }
        EL I ch == "J" { result = result + "j" }
        EL I ch == "K" { result = result + "k" }
        EL I ch == "L" { result = result + "l" }
        EL I ch == "M" { result = result + "m" }
        EL I ch == "N" { result = result + "n" }
        EL I ch == "O" { result = result + "o" }
        EL I ch == "P" { result = result + "p" }
        EL I ch == "Q" { result = result + "q" }
        EL I ch == "R" { result = result + "r" }
        EL I ch == "S" { result = result + "s" }
        EL I ch == "T" { result = result + "t" }
        EL I ch == "U" { result = result + "u" }
        EL I ch == "V" { result = result + "v" }
        EL I ch == "W" { result = result + "w" }
        EL I ch == "X" { result = result + "x" }
        EL I ch == "Y" { result = result + "y" }
        EL I ch == "Z" { result = result + "z" }
        EL { result = result + ch }
        i = i + 1
    }
    R result
}

F str_to_upper(s: &str) -> str {
    slen := str_len(s)
    result := ""
    i := 0
    LW i < slen {
        ch := str_char_at(s, i)
        I ch == "a" { result = result + "A" }
        EL I ch == "b" { result = result + "B" }
        EL I ch == "c" { result = result + "C" }
        EL I ch == "d" { result = result + "D" }
        EL I ch == "e" { result = result + "E" }
        EL I ch == "f" { result = result + "F" }
        EL I ch == "g" { result = result + "G" }
        EL I ch == "h" { result = result + "H" }
        EL I ch == "i" { result = result + "I" }
        EL I ch == "j" { result = result + "J" }
        EL I ch == "k" { result = result + "K" }
        EL I ch == "l" { result = result + "L" }
        EL I ch == "m" { result = result + "M" }
        EL I ch == "n" { result = result + "N" }
        EL I ch == "o" { result = result + "O" }
        EL I ch == "p" { result = result + "P" }
        EL I ch == "q" { result = result + "Q" }
        EL I ch == "r" { result = result + "R" }
        EL I ch == "s" { result = result + "S" }
        EL I ch == "t" { result = result + "T" }
        EL I ch == "u" { result = result + "U" }
        EL I ch == "v" { result = result + "V" }
        EL I ch == "w" { result = result + "W" }
        EL I ch == "x" { result = result + "X" }
        EL I ch == "y" { result = result + "Y" }
        EL I ch == "z" { result = result + "Z" }
        EL { result = result + ch }
        i = i + 1
    }
    R result
}

F str_replace(s: &str, old: &str, new_val: &str) -> str {
    slen := str_len(s)
    oldlen := str_len(old)
    I oldlen == 0 {
        R s
    }
    result := ""
    i := 0
    LW i <= slen - oldlen {
        chunk := str_slice(s, i, i + oldlen)
        I chunk == old {
            result = result + new_val
            i = i + oldlen
        } EL {
            result = result + str_char_at(s, i)
            i = i + 1
        }
    }
    LW i < slen {
        result = result + str_char_at(s, i)
        i = i + 1
    }
    R result
}

