
# ============================================================================
# 알림 평가 워커
# vais async 기능 활용: A (async), Y (await), LW (loop while)
# ============================================================================

# 워커 실행 여부 전역 플래그
G alert_eval_running: bool = true

# 알림 평가 워커 시작 (main.vais에서 spawn으로 호출)
# 무한 루프: enabled 알림 룰 전체 평가 → 1분 대기
A F start_alert_eval_worker() {
    println("[alert_eval] Worker started")

    LW true {
        I alert_eval_running == false {
            println("[alert_eval] Worker stopped")
            R
        }

        evaluate_all_alerts()

        sleep_ms(60000)   # 1분마다 평가.await
    }
}

# ============================================================================
# 전체 알림 룰 순회 평가
# ============================================================================

# 활성화된 모든 알림 룰을 순회하여 평가
# enabled=1 AND muted_until < now 인 룰만 처리
F evaluate_all_alerts() {
    # enabled 룰 수를 동적으로 조회 (하드캡 없음)
    count_row := db_query("SELECT COUNT(*) as cnt FROM alert_rules WHERE enabled = 1")
    cnt_str := json_get(count_row, "cnt")
    count := I str_len(cnt_str) > 0 { str_to_i64(cnt_str) } EL { 0 }

    evaluated := mut 0
    i := mut 0
    LW i < count {
        rule_row := db_query(
            "SELECT id, team_id, service_id, name, condition_metric, condition_op, " +
            "condition_value, duration_sec, severity, channel, channel_config, enabled, muted_until " +
            "FROM alert_rules WHERE enabled = 1 ORDER BY id ASC LIMIT 1 OFFSET " + i64_to_str(i)
        )
        rule_id_str := json_get(rule_row, "id")
        I str_len(rule_id_str) > 0 {
            evaluate_single_alert(rule_row)
            evaluated = evaluated + 1
        }
        i = i + 1
    }

    ts := i64_to_str(current_time_ms())
    println("[alert_eval] Evaluation cycle completed at " + ts + " (" + i64_to_str(evaluated) + " rules evaluated)")
}

# ============================================================================
# 개별 알림 평가
# ============================================================================

# alert JSON에서 필드 추출 후 메트릭 조회 → 조건 평가 → 인시던트 생성
F evaluate_single_alert(alert_json: str) {
    # alert JSON에서 필드 추출
    alert_id := str_to_i64(json_get(alert_json, "id"))
    service_id := str_to_i64(json_get(alert_json, "service_id"))
    condition_metric := json_get(alert_json, "condition_metric")
    condition_op := json_get(alert_json, "condition_op")
    condition_value := str_to_f64(json_get(alert_json, "condition_value"))
    severity := json_get(alert_json, "severity")
    alert_name := json_get(alert_json, "name")
    duration_sec := str_to_i64(json_get(alert_json, "duration_sec"))

    # 필수 필드 검증
    I alert_id == 0 {
        R
    }
    I str_len(condition_metric) == 0 {
        R
    }
    I str_len(condition_op) == 0 {
        R
    }

    # service_id=0 이면 전체 서비스 → 첫 번째 서비스 대상으로 평가 (간소화)
    # 실제 구현에서는 서비스별로 순회
    target_service_id := I service_id > 0 { service_id } EL { 1 }

    # 메트릭 조회: duration_sec 윈도우 내 집계값 사용
    now_ms := current_time_ms()
    now_sec := now_ms / 1000
    from_ts_ms := now_ms - (duration_sec * 1000)

    # 최신 단일 메트릭 값으로 평가 (빠른 체크)
    latest_metric := get_latest_metric(target_service_id, condition_metric)
    actual_value := 0.0

    I str_len(latest_metric) > 0 {
        # 최신 메트릭이 duration_sec 윈도우 안에 있는지 확인
        metric_ts_ms := str_to_i64(json_get(latest_metric, "timestamp"))
        in_window := metric_ts_ms >= from_ts_ms

        I in_window {
            # 집계값 사용 (duration_sec 윈도우 내 평균)
            agg := aggregate_metrics(target_service_id, condition_metric, from_ts_ms, now_ms)
            agg_count := str_to_i64(json_get(agg, "count"))

            actual_value = I agg_count > 0 {
                str_to_f64(json_get(agg, "avg"))
            } EL {
                str_to_f64(json_get(latest_metric, "value"))
            }

            # 조건 평가
            triggered := evaluate_condition(condition_op, actual_value, condition_value)

            I triggered {
                # 중복 인시던트 방지: 이미 open 인시던트가 있으면 새로 만들지 않음
                existing_incident := find_open_incident(alert_id, target_service_id)
                I str_len(existing_incident) == 0 {
                    # 인시던트 생성
                    title := "[" + severity + "] " + alert_name + " triggered"
                    description := "Metric " + condition_metric +
                        " is " + condition_op + " " + f64_to_str(condition_value) +
                        " (actual: " + f64_to_str(actual_value) + ")"
                    create_incident(alert_id, target_service_id, title, description, severity)
                    println("[alert_eval] Incident created for alert_id=" + i64_to_str(alert_id) +
                        " service_id=" + i64_to_str(target_service_id) +
                        " metric=" + condition_metric +
                        " actual=" + f64_to_str(actual_value))
                } EL {
                    println("[alert_eval] Open incident already exists for alert_id=" + i64_to_str(alert_id) +
                        " service_id=" + i64_to_str(target_service_id) + ", skipping")
                }
            }
        }
    }
}

# ============================================================================
# 워커 중지
# ============================================================================

# 워커 graceful shutdown
F stop_alert_eval_worker() {
    alert_eval_running = false
    println("[alert_eval] Worker stopping")
}
