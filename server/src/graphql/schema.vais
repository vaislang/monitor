    end_pos := I end_pos == end_idx && is_end16 { 16 } EL { end_pos }
    end_pos := I end_pos == end_idx && is_end17 { 17 } EL { end_pos }
    end_pos := I end_pos == end_idx && is_end18 { 18 } EL { end_pos }
    end_pos := I end_pos == end_idx && is_end19 { 19 } EL { end_pos }

    I end_pos == 0 {
        ""
    } EL {
        str_slice(s, 0, end_pos)
    }
}
