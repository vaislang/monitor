
# ============================================================================
# 워커 단위 테스트
# ============================================================================

# 간단한 assert 함수 (worker_test 전용 — integration_test와 동일 패턴)
F assert(condition: bool, message: str) {
    I !condition {
        panic("ASSERTION FAILED: " + message)
    }
    println("  PASS: " + message)
}

F assert_eq_str(actual: str, expected: str, message: str) {
    I actual != expected {
        panic("ASSERTION FAILED: " + message + " | expected='" + expected + "' got='" + actual + "'")
    }
    println("  PASS: " + message)
}

# ============================================================================
# TEST: evaluate_condition — gt 연산자
# ============================================================================

F test_evaluate_condition_gt() {
    println("[test_evaluate_condition_gt] start")

    # true 케이스: 95.0 > 90.0
    result := evaluate_condition("gt", 95.0, 90.0)
    assert(result == true, "95 > 90 should be true")

    # false 케이스: 85.0 > 90.0
    result2 := evaluate_condition("gt", 85.0, 90.0)
    assert(result2 == false, "85 > 90 should be false")

    # 경계값 — 정확히 같은 경우: 90.0 > 90.0 → false
    result3 := evaluate_condition("gt", 90.0, 90.0)
    assert(result3 == false, "90 > 90 should be false (strict greater)")

    println("[test_evaluate_condition_gt] PASSED")
}

# ============================================================================
# TEST: evaluate_condition — lt 연산자
# ============================================================================

F test_evaluate_condition_lt() {
    println("[test_evaluate_condition_lt] start")

    # true 케이스: 80.0 < 90.0
    result := evaluate_condition("lt", 80.0, 90.0)
    assert(result == true, "80 < 90 should be true")

    # false 케이스: 95.0 < 90.0
    result2 := evaluate_condition("lt", 95.0, 90.0)
    assert(result2 == false, "95 < 90 should be false")

    # 경계값 — 정확히 같은 경우: 90.0 < 90.0 → false
    result3 := evaluate_condition("lt", 90.0, 90.0)
    assert(result3 == false, "90 < 90 should be false (strict less)")

    println("[test_evaluate_condition_lt] PASSED")
}

# ============================================================================
# TEST: evaluate_condition — eq 연산자
# ============================================================================

F test_evaluate_condition_eq() {
    println("[test_evaluate_condition_eq] start")

    # true 케이스: 90.0 == 90.0
    result := evaluate_condition("eq", 90.0, 90.0)
    assert(result == true, "90 == 90 should be true")

    # false 케이스: 91.0 == 90.0
    result2 := evaluate_condition("eq", 91.0, 90.0)
    assert(result2 == false, "91 == 90 should be false")

    println("[test_evaluate_condition_eq] PASSED")
}

# ============================================================================
# TEST: evaluate_condition — gte 연산자
# ============================================================================

F test_evaluate_condition_gte() {
    println("[test_evaluate_condition_gte] start")

    # true 케이스: 95.0 >= 90.0 (초과)
    result := evaluate_condition("gte", 95.0, 90.0)
    assert(result == true, "95 >= 90 should be true (greater)")

    # true 케이스: 90.0 >= 90.0 (같음)
    result2 := evaluate_condition("gte", 90.0, 90.0)
    assert(result2 == true, "90 >= 90 should be true (equal)")

    # false 케이스: 85.0 >= 90.0
    result3 := evaluate_condition("gte", 85.0, 90.0)
    assert(result3 == false, "85 >= 90 should be false")

    println("[test_evaluate_condition_gte] PASSED")
}

# ============================================================================
# TEST: evaluate_condition — lte 연산자
# ============================================================================

F test_evaluate_condition_lte() {
    println("[test_evaluate_condition_lte] start")

    # true 케이스: 85.0 <= 90.0 (미만)
    result := evaluate_condition("lte", 85.0, 90.0)
    assert(result == true, "85 <= 90 should be true (less)")

    # true 케이스: 90.0 <= 90.0 (같음)
    result2 := evaluate_condition("lte", 90.0, 90.0)
    assert(result2 == true, "90 <= 90 should be true (equal)")

    # false 케이스: 95.0 <= 90.0
    result3 := evaluate_condition("lte", 95.0, 90.0)
    assert(result3 == false, "95 <= 90 should be false")

    println("[test_evaluate_condition_lte] PASSED")
}

# ============================================================================
# TEST: evaluate_condition — 알 수 없는 연산자
# ============================================================================

F test_evaluate_condition_unknown_op() {
    println("[test_evaluate_condition_unknown_op] start")

    # 알 수 없는 연산자는 항상 false를 반환
    result := evaluate_condition("ne", 50.0, 30.0)
    assert(result == false, "unknown op 'ne' should return false")

    result2 := evaluate_condition("", 100.0, 0.0)
    assert(result2 == false, "empty op should return false")

    println("[test_evaluate_condition_unknown_op] PASSED")
}

# ============================================================================
# TEST: determine_status — 헬스체크 상태 판단
# ============================================================================

F test_determine_status_up() {
    println("[test_determine_status_up] start")

    # 정상 응답 + 빠른 응답 시간 → up
    status := determine_status("ok", 200)
    assert_eq_str(status, "up", "ok response with 200ms should be 'up'")

    # 정상 응답 + 응답 시간 경계 미만 → up
    status2 := determine_status("ok", 4999)
    assert_eq_str(status2, "up", "ok response with 4999ms should be 'up'")

    println("[test_determine_status_up] PASSED")
}

F test_determine_status_degraded() {
    println("[test_determine_status_degraded] start")

    # 정상 응답이지만 응답 시간이 5000ms 초과 → degraded
    status := determine_status("ok", 5001)
    assert_eq_str(status, "degraded", "ok response with 5001ms should be 'degraded'")

    # 정상 응답 + 매우 긴 응답 시간 → degraded
    status2 := determine_status("ok", 30000)
    assert_eq_str(status2, "degraded", "ok response with 30000ms should be 'degraded'")

    println("[test_determine_status_degraded] PASSED")
}

F test_determine_status_down() {
    println("[test_determine_status_down] start")

    # error 응답 → down
    status := determine_status("error", 100)
    assert_eq_str(status, "down", "error response should be 'down'")

    # 빈 응답 → down
    status2 := determine_status("", 100)
    assert_eq_str(status2, "down", "empty response should be 'down'")

    # error 응답 + 느린 응답 시간 → down (response 우선)
    status3 := determine_status("error", 10000)
    assert_eq_str(status3, "down", "error response with high latency should be 'down'")

    println("[test_determine_status_down] PASSED")
}

# ============================================================================
# TEST: calculate_zscore — z-score 계산
# ============================================================================

F test_calculate_zscore_normal() {
    println("[test_calculate_zscore_normal] start")

    # 정상 범위 값: 평균 50, 표준편차 10, 현재 값 55 → z-score = 0.5
    z := calculate_zscore(55.0, 50.0, 10.0)
    # z = |55 - 50| / 10 = 0.5 — 0.49~0.51 허용 범위
    assert(z > 0.49, "z-score of (55, mean=50, std=10) should be > 0.49")
    assert(z < 0.51, "z-score of (55, mean=50, std=10) should be < 0.51")

    # 평균값 자체 → z-score = 0
    z2 := calculate_zscore(50.0, 50.0, 10.0)
    assert(z2 == 0.0, "z-score of mean value should be 0.0")

    println("[test_calculate_zscore_normal] PASSED")
}

F test_calculate_zscore_outlier() {
    println("[test_calculate_zscore_outlier] start")

    # 이상치: 평균 50, 표준편차 10, 현재 값 80 → z-score = 3.0 (이상치)
    z := calculate_zscore(80.0, 50.0, 10.0)
    # z = |80 - 50| / 10 = 3.0
    assert(z > 2.99, "z-score of (80, mean=50, std=10) should be > 2.99")
    assert(z < 3.01, "z-score of (80, mean=50, std=10) should be < 3.01")

    # 음의 방향 이상치: 현재 값이 평균보다 훨씬 낮은 경우 — 절댓값 반환
    z2 := calculate_zscore(20.0, 50.0, 10.0)
    # z = |20 - 50| / 10 = 3.0 (절댓값)
    assert(z2 > 2.99, "z-score of (20, mean=50, std=10) should be 3.0 (abs)")
    assert(z2 < 3.01, "z-score of (20, mean=50, std=10) should be 3.0 (abs)")

    println("[test_calculate_zscore_outlier] PASSED")
}

F test_calculate_zscore_zero_stddev() {
    println("[test_calculate_zscore_zero_stddev] start")

    # 표준편차가 0이면 z-score 계산 불가 → 0 반환
    z := calculate_zscore(95.0, 50.0, 0.0)
    assert(z == 0.0, "z-score with stddev=0 should return 0.0")

    # 음의 표준편차도 동일하게 0 반환
    z2 := calculate_zscore(100.0, 50.0, -5.0)
    assert(z2 == 0.0, "z-score with negative stddev should return 0.0")

    println("[test_calculate_zscore_zero_stddev] PASSED")
}

# ============================================================================
# 전체 워커 테스트 실행
# ============================================================================

F run_worker_tests() {
    println("=== Vais Monitor Worker Unit Tests ===")

    test_evaluate_condition_gt()
    test_evaluate_condition_lt()
    test_evaluate_condition_eq()
    test_evaluate_condition_gte()
    test_evaluate_condition_lte()
    test_evaluate_condition_unknown_op()

    test_determine_status_up()
    test_determine_status_degraded()
    test_determine_status_down()

    test_calculate_zscore_normal()
    test_calculate_zscore_outlier()
    test_calculate_zscore_zero_stddev()

    println("=== All worker tests passed! ===")
}
