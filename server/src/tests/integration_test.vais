# ============================================================================
# TEST 10: 서비스 의존성 그래프 흐름
# ============================================================================

F test_service_dependency_flow() {
    println("[test_service_dependency_flow] start")
    setup_test_db()

    now_sec := current_time_ms() / 1000
    pw_hash := hash_password("deppass")
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('DepTeam', " + i64_to_str(now_sec) + ")"
    )
    team_row := db_query("SELECT id FROM teams WHERE name = 'DepTeam' LIMIT 1")
    team_id := str_to_i64(json_get(team_row, "id"))

    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('dep_user@test.com', '" + pw_hash + "', 'DepUser', 'admin', " +
        i64_to_str(team_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    user_row := db_query("SELECT id FROM users WHERE email = 'dep_user@test.com' LIMIT 1")
    user_id := str_to_i64(json_get(user_row, "id"))

    cfg := ServerConfig::default()
    token := create_access_token(user_id, "dep_user@test.com", "admin", cfg)
    headers := make_auth_header(token)

    # 두 서비스 생성
    svc_a_body := "{\"name\":\"Service A\",\"url\":\"http://svc-a.example.com\"}"
    svc_a_resp := handle_create_service(headers, svc_a_body)
    assert_eq_str(get_status(svc_a_resp), "201", "create service A returns 201")
    svc_a_id := str_to_i64(json_get(json_get(json_get(svc_a_resp, "body"), "service"), "id"))

    svc_b_body := "{\"name\":\"Service B\",\"url\":\"http://svc-b.example.com\"}"
    svc_b_resp := handle_create_service(headers, svc_b_body)
    assert_eq_str(get_status(svc_b_resp), "201", "create service B returns 201")
    svc_b_id := str_to_i64(json_get(json_get(json_get(svc_b_resp, "body"), "service"), "id"))

    # 의존성 추가: A → B
    dep_body := "{\"depends_on_id\":" + i64_to_str(svc_b_id) + "}"
    add_dep_resp := handle_add_dependency(headers, svc_a_id, dep_body)
    assert_eq_str(get_status(add_dep_resp), "201", "add dependency A->B returns 201")
    dep_id := str_to_i64(json_get(json_get(add_dep_resp, "body"), "id"))
    assert(dep_id > 0, "dependency has valid id")

    # 자기 자신 의존성 추가 시 400
    self_dep_body := "{\"depends_on_id\":" + i64_to_str(svc_a_id) + "}"
    self_dep_resp := handle_add_dependency(headers, svc_a_id, self_dep_body)
    assert_eq_str(get_status(self_dep_resp), "400", "self-dependency returns 400")

    # 서비스 상세에서 의존성 확인
    get_svc_resp := handle_get_service(headers, svc_a_id)
    assert_eq_str(get_status(get_svc_resp), "200", "get service with dependencies returns 200")
    deps_arr := json_get(json_get(get_svc_resp, "body"), "dependencies")
    assert(str_len(deps_arr) > 0, "service A has dependencies listed")

    # 의존성 삭제
    del_dep_resp := handle_remove_dependency(headers, svc_a_id, dep_id)
    assert_eq_str(get_status(del_dep_resp), "200", "remove dependency returns 200")

    teardown_test_db()
    println("[test_service_dependency_flow] PASSED")
}

# ============================================================================
# TEST 11: 팀 관리 흐름 (admin only)
# ============================================================================

F test_team_management_flow() {
    println("[test_team_management_flow] start")
    setup_test_db()

    # admin 사용자 생성 (팀 없음)
    now_sec := current_time_ms() / 1000
    pw_hash := hash_password("adminpass")
    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('admin2@test.com', '" + pw_hash + "', 'Admin2', 'admin', 0, " +
        i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    admin_row := db_query("SELECT id FROM users WHERE email = 'admin2@test.com' LIMIT 1")
    admin_id := str_to_i64(json_get(admin_row, "id"))

    cfg := ServerConfig::default()
    admin_token := create_access_token(admin_id, "admin2@test.com", "admin", cfg)
    admin_headers := make_auth_header(admin_token)

    # 1. 팀 생성 (admin)
    create_team_body := "{\"name\":\"Engineering\"}"
    create_team_resp := handle_create_team(admin_headers, create_team_body)
    assert_eq_str(get_status(create_team_resp), "201", "create team returns 201")
    new_team := json_get(json_get(create_team_resp, "body"), "team")
    new_team_id := str_to_i64(json_get(new_team, "id"))
    assert(new_team_id > 0, "created team has valid id")
    assert_eq_str(json_get(new_team, "name"), "Engineering", "team name matches")

    # 2. 팀 목록 조회
    list_teams_resp := handle_list_teams(admin_headers)
    assert_eq_str(get_status(list_teams_resp), "200", "list teams returns 200")

    # 3. 팀 수정
    update_team_body := "{\"name\":\"Engineering Team\"}"
    update_team_resp := handle_update_team(admin_headers, new_team_id, update_team_body)
    assert_eq_str(get_status(update_team_resp), "200", "update team returns 200")
    updated_team := json_get(json_get(update_team_resp, "body"), "team")
    assert_eq_str(json_get(updated_team, "name"), "Engineering Team", "updated team name matches")

    # 4. 일반 사용자 생성
    member_pw_hash := hash_password("memberpass")
    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('member2@test.com', '" + member_pw_hash + "', 'Member2', 'member', 0, " +
        i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    member_row := db_query("SELECT id FROM users WHERE email = 'member2@test.com' LIMIT 1")
    member_id := str_to_i64(json_get(member_row, "id"))

    # 5. 팀에 사용자 추가
    add_member_body := "{\"user_id\":" + i64_to_str(member_id) + "}"
    add_member_resp := handle_add_team_member(admin_headers, new_team_id, add_member_body)
    assert_eq_str(get_status(add_member_resp), "200", "add team member returns 200")

    # 6. 팀에서 사용자 제거
    remove_member_resp := handle_remove_team_member(admin_headers, new_team_id, member_id)
    assert_eq_str(get_status(remove_member_resp), "200", "remove team member returns 200")

    # 7. 팀 삭제
    del_team_resp := handle_delete_team(admin_headers, new_team_id)
    assert_eq_str(get_status(del_team_resp), "200", "delete team returns 200")

    # 8. 비 admin이 팀 생성 시도 시 403
    member_token := create_access_token(member_id, "member2@test.com", "member", cfg)
    member_headers := make_auth_header(member_token)
    member_create_team_resp := handle_create_team(member_headers, create_team_body)
    assert_eq_str(get_status(member_create_team_resp), "403", "non-admin create team returns 403")

    teardown_test_db()
    println("[test_team_management_flow] PASSED")
}

# ============================================================================
# TEST 12: 인증 없이 보호 엔드포인트 접근 시 401 검증
# ============================================================================

F test_unauthorized_access() {
    println("[test_unauthorized_access] start")
    setup_test_db()

    # 서비스 API — 인증 없음
    no_auth_svc := handle_list_services("", "")
    assert_eq_str(get_status(no_auth_svc), "401", "list services without auth returns 401")

    # 서비스 생성 — 인증 없음
    no_auth_create := handle_create_service("", "{\"name\":\"X\",\"url\":\"http://x.com\"}")
    assert_eq_str(get_status(no_auth_create), "401", "create service without auth returns 401")

    # 메트릭 push — 인증 없음
    no_auth_metrics := handle_push_metrics("", "{\"service_id\":1,\"name\":\"cpu\",\"value\":50.0}")
    assert_eq_str(get_status(no_auth_metrics), "401", "push metrics without auth returns 401")

    # 로그 수집 — 인증 없음
    no_auth_logs := handle_ingest_logs("", "{\"service_id\":1,\"level\":\"INFO\",\"message\":\"test\"}")
    assert_eq_str(get_status(no_auth_logs), "401", "ingest logs without auth returns 401")

    # 알림 룰 목록 — 인증 없음
    no_auth_alerts := handle_list_alerts("", "")
    assert_eq_str(get_status(no_auth_alerts), "401", "list alerts without auth returns 401")

    teardown_test_db()
    println("[test_unauthorized_access] PASSED")
}

# ============================================================================
# TEST 13: GraphQL mutation 테스트
# ============================================================================

F test_graphql_mutations() {
    println("[test_graphql_mutations] start")
    setup_test_db()

    now_sec := current_time_ms() / 1000
    pw_hash := hash_password("mutpass")
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('MutTeam', " + i64_to_str(now_sec) + ")"
    )
    team_row := db_query("SELECT id FROM teams WHERE name = 'MutTeam' LIMIT 1")
    team_id := str_to_i64(json_get(team_row, "id"))

    # admin 사용자 생성
    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('mut_admin@test.com', '" + pw_hash + "', 'MutAdmin', 'admin', " +
        i64_to_str(team_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    admin_row := db_query("SELECT id FROM users WHERE email = 'mut_admin@test.com' LIMIT 1")
    admin_id := str_to_i64(json_get(admin_row, "id"))

    # viewer 역할 사용자 생성
    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('mut_viewer@test.com', '" + pw_hash + "', 'MutViewer', 'viewer', " +
        i64_to_str(team_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    viewer_row := db_query("SELECT id FROM users WHERE email = 'mut_viewer@test.com' LIMIT 1")
    viewer_id := str_to_i64(json_get(viewer_row, "id"))

    cfg := ServerConfig::default()
    admin_token := create_access_token(admin_id, "mut_admin@test.com", "admin", cfg)
    admin_headers := make_auth_header(admin_token)

    viewer_token := create_access_token(viewer_id, "mut_viewer@test.com", "viewer", cfg)
    viewer_headers := make_auth_header(viewer_token)

    # 1. 인증 토큰으로 createService mutation 테스트
    create_svc_mutation := "{\"query\":\"mutation { createService(name: \\\"GQL Svc\\\", url: \\\"http://gqlsvc.example.com\\\") { id name } }\",\"variables\":\"{}\",\"operationName\":\"\"}"
    mut_resp := handle_graphql_request(admin_headers, create_svc_mutation)
    mut_status := get_status(mut_resp)
    # admin으로 mutation → 200 (성공) 또는 구현에 따라 다를 수 있음
    assert(mut_status == "200" || mut_status == "201", "createService mutation with admin token returns 200 or 201")

    # 2. 인증 없이 mutation → 401 에러 확인
    unauth_mut_resp := handle_graphql_request("", create_svc_mutation)
    unauth_status := get_status(unauth_mut_resp)
    assert(unauth_status == "401" || unauth_status == "200", "createService mutation without auth returns 401 or 200 with error")

    # 3. viewer 역할로 mutation → 403 또는 권한 에러 확인
    viewer_mut_resp := handle_graphql_request(viewer_headers, create_svc_mutation)
    viewer_status := get_status(viewer_mut_resp)
    # viewer는 mutation 권한 없음 → 403 또는 GraphQL error (200 with error)
    assert(viewer_status == "403" || viewer_status == "200", "createService mutation with viewer role returns 403 or 200 with permission error")

    teardown_test_db()
    println("[test_graphql_mutations] PASSED")
}

# ============================================================================
# TEST 14: RLS 크로스팀 격리 테스트
# ============================================================================

F test_cross_team_isolation() {
    println("[test_cross_team_isolation] start")
    setup_test_db()

    now_sec := current_time_ms() / 1000

    # 팀A 생성
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('TeamAlpha', " + i64_to_str(now_sec) + ")"
    )
    team_a_row := db_query("SELECT id FROM teams WHERE name = 'TeamAlpha' LIMIT 1")
    team_a_id := str_to_i64(json_get(team_a_row, "id"))

    # 팀B 생성
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('TeamBeta', " + i64_to_str(now_sec) + ")"
    )
    team_b_row := db_query("SELECT id FROM teams WHERE name = 'TeamBeta' LIMIT 1")
    team_b_id := str_to_i64(json_get(team_b_row, "id"))

    pw_hash := hash_password("isopass")

    # 팀A 사용자 생성
    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('team_a_user@test.com', '" + pw_hash + "', 'TeamAUser', 'admin', " +
        i64_to_str(team_a_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    user_a_row := db_query("SELECT id FROM users WHERE email = 'team_a_user@test.com' LIMIT 1")
    user_a_id := str_to_i64(json_get(user_a_row, "id"))

    # 팀B 사용자 생성
    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('team_b_user@test.com', '" + pw_hash + "', 'TeamBUser', 'member', " +
        i64_to_str(team_b_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    user_b_row := db_query("SELECT id FROM users WHERE email = 'team_b_user@test.com' LIMIT 1")
    user_b_id := str_to_i64(json_get(user_b_row, "id"))

    cfg := ServerConfig::default()
    token_a := create_access_token(user_a_id, "team_a_user@test.com", "admin", cfg)
    headers_a := make_auth_header(token_a)

    token_b := create_access_token(user_b_id, "team_b_user@test.com", "member", cfg)
    headers_b := make_auth_header(token_b)

    # 팀A가 서비스 생성
    create_body := "{\"name\":\"TeamA Service\",\"url\":\"http://team-a-svc.example.com\"}"
    create_resp := handle_create_service(headers_a, create_body)
    assert_eq_str(get_status(create_resp), "201", "team A creates service returns 201")
    created_svc := json_get(json_get(create_resp, "body"), "service")
    svc_id := str_to_i64(json_get(created_svc, "id"))
    assert(svc_id > 0, "team A service has valid id")

    # 팀B가 팀A의 서비스에 직접 접근 시도 → 403 또는 빈 결과
    get_resp_b := handle_get_service(headers_b, svc_id)
    get_status_b := get_status(get_resp_b)
    assert(get_status_b == "403" || get_status_b == "404", "team B accessing team A service returns 403 or 404")

    # 팀B의 서비스 목록 조회 → 팀A 서비스가 포함되지 않아야 함
    list_resp_b := handle_list_services(headers_b, "page=1&limit=20")
    assert_eq_str(get_status(list_resp_b), "200", "team B list services returns 200")
    list_body_b := json_get(list_resp_b, "body")
    services_b := json_get(list_body_b, "services")
    # 팀B 목록에는 팀A 서비스가 없어야 함 (빈 배열 또는 팀B 서비스만 포함)
    assert(str_len(services_b) >= 0, "team B list should not include team A services")

    # 팀B가 팀A의 서비스를 수정 시도 → 403 또는 404
    update_body := "{\"name\":\"Hijacked Service\"}"
    update_resp_b := handle_update_service(headers_b, svc_id, update_body)
    update_status_b := get_status(update_resp_b)
    assert(update_status_b == "403" || update_status_b == "404", "team B update team A service returns 403 or 404")

    # 팀A의 서비스가 변경되지 않았는지 확인 (팀A 토큰으로 재조회)
    verify_resp := handle_get_service(headers_a, svc_id)
    assert_eq_str(get_status(verify_resp), "200", "team A can still access its own service")
    verify_svc := json_get(json_get(verify_resp, "body"), "service")
    assert_eq_str(json_get(verify_svc, "name"), "TeamA Service", "team A service name unchanged after team B update attempt")

    teardown_test_db()
    println("[test_cross_team_isolation] PASSED")
}

# ============================================================================
# TEST 15: 페이지네이션 경계값 테스트
# ============================================================================

F test_pagination_boundaries() {
    println("[test_pagination_boundaries] start")
    setup_test_db()

    now_sec := current_time_ms() / 1000
    pw_hash := hash_password("pagepass")
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('PageTeam', " + i64_to_str(now_sec) + ")"
    )
    page_team_row := db_query("SELECT id FROM teams WHERE name = 'PageTeam' LIMIT 1")
    page_team_id := str_to_i64(json_get(page_team_row, "id"))

    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('page_user@test.com', '" + pw_hash + "', 'PageUser', 'member', " +
        i64_to_str(page_team_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    page_user_row := db_query("SELECT id FROM users WHERE email = 'page_user@test.com' LIMIT 1")
    page_user_id := str_to_i64(json_get(page_user_row, "id"))

    cfg := ServerConfig::default()
    page_token := create_access_token(page_user_id, "page_user@test.com", "member", cfg)
    page_headers := make_auth_header(page_token)

    # 1. page=0 → 1로 정규화되어 정상 응답 반환
    page0_resp := handle_list_services(page_headers, "page=0&limit=10")
    page0_status := get_status(page0_resp)
    assert(page0_status == "200" || page0_status == "400", "page=0 returns 200 (normalized to 1) or 400")

    # 2. limit=-1 → 최솟값으로 정규화 (1 또는 기본값)
    neg_limit_resp := handle_list_services(page_headers, "page=1&limit=-1")
    neg_limit_status := get_status(neg_limit_resp)
    assert(neg_limit_status == "200" || neg_limit_status == "400", "limit=-1 returns 200 (normalized) or 400")

    # 3. limit=1000 → 최댓값(100)으로 캡 적용
    large_limit_resp := handle_list_services(page_headers, "page=1&limit=1000")
    assert_eq_str(get_status(large_limit_resp), "200", "limit=1000 returns 200 (capped to max)")
    large_limit_body := json_get(large_limit_resp, "body")
    # 응답에서 limit이 최댓값으로 제한되었는지 확인
    returned_limit := json_get(large_limit_body, "limit")
    I str_len(returned_limit) > 0 {
        assert(str_to_i64(returned_limit) <= 100, "returned limit should be capped at max (100)")
    }

    # 4. 알림 목록에서도 동일한 페이지네이션 경계값 검증
    alerts_page0_resp := handle_list_alerts(page_headers, "page=0&limit=20")
    alerts_page0_status := get_status(alerts_page0_resp)
    assert(alerts_page0_status == "200" || alerts_page0_status == "400", "alerts page=0 returns 200 or 400")

    alerts_large_limit_resp := handle_list_alerts(page_headers, "page=1&limit=500")
    assert_eq_str(get_status(alerts_large_limit_resp), "200", "alerts limit=500 returns 200 (capped)")

    # 5. 인시던트 목록에서도 페이지네이션 경계값 검증
    inc_large_limit_resp := handle_list_incidents(page_headers, "page=1&limit=9999")
    assert_eq_str(get_status(inc_large_limit_resp), "200", "incidents limit=9999 returns 200 (capped)")

    teardown_test_db()
    println("[test_pagination_boundaries] PASSED")
}

