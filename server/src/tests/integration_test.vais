    test_user_profile_flow()
    test_service_dependency_flow()
    test_team_management_flow()
    test_unauthorized_access()
    test_graphql_mutations()
    test_cross_team_isolation()
    test_pagination_boundaries()

    println("=== All integration tests passed! ===")
}
