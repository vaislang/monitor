
# ============================================================================
# 통합 테스트 헬퍼
# ============================================================================

# DB 초기화 (테스트 전용 인메모리 DB)
F setup_test_db() {
    db_connect(":memory:")

    db_execute(
        "CREATE TABLE IF NOT EXISTS teams (" +
        "  id INTEGER PRIMARY KEY," +
        "  name TEXT NOT NULL UNIQUE," +
        "  created_at INTEGER NOT NULL" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS users (" +
        "  id INTEGER PRIMARY KEY," +
        "  email TEXT NOT NULL UNIQUE," +
        "  password_hash TEXT NOT NULL," +
        "  name TEXT NOT NULL," +
        "  role TEXT NOT NULL DEFAULT 'member'," +
        "  team_id INTEGER DEFAULT 0," +
        "  oauth_provider TEXT DEFAULT ''," +
        "  oauth_id TEXT DEFAULT ''," +
        "  created_at INTEGER NOT NULL," +
        "  updated_at INTEGER NOT NULL" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS sessions (" +
        "  id INTEGER PRIMARY KEY," +
        "  user_id INTEGER NOT NULL," +
        "  refresh_token TEXT NOT NULL UNIQUE," +
        "  expires_at INTEGER NOT NULL," +
        "  created_at INTEGER NOT NULL" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS services (" +
        "  id INTEGER PRIMARY KEY," +
        "  team_id INTEGER NOT NULL," +
        "  name TEXT NOT NULL," +
        "  url TEXT NOT NULL," +
        "  health_endpoint TEXT DEFAULT '/health'," +
        "  check_interval_sec INTEGER DEFAULT 60," +
        "  status TEXT DEFAULT 'unknown'," +
        "  tags TEXT DEFAULT ''," +
        "  created_at INTEGER NOT NULL," +
        "  updated_at INTEGER NOT NULL" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS service_dependencies (" +
        "  id INTEGER PRIMARY KEY," +
        "  service_id INTEGER NOT NULL," +
        "  depends_on_id INTEGER NOT NULL," +
        "  created_at INTEGER NOT NULL" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS service_graph_nodes (" +
        "  id INTEGER PRIMARY KEY," +
        "  service_id INTEGER NOT NULL UNIQUE," +
        "  name TEXT NOT NULL," +
        "  status TEXT DEFAULT 'unknown'," +
        "  created_at INTEGER NOT NULL" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS service_graph_edges (" +
        "  id INTEGER PRIMARY KEY," +
        "  from_service_id INTEGER NOT NULL," +
        "  to_service_id INTEGER NOT NULL," +
        "  created_at INTEGER NOT NULL" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS metrics (" +
        "  id INTEGER PRIMARY KEY," +
        "  service_id INTEGER NOT NULL," +
        "  metric_name TEXT NOT NULL," +
        "  value REAL NOT NULL," +
        "  timestamp INTEGER NOT NULL," +
        "  ttl_seconds INTEGER DEFAULT 2592000" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS logs (" +
        "  id INTEGER PRIMARY KEY," +
        "  service_id INTEGER NOT NULL," +
        "  level TEXT NOT NULL," +
        "  message TEXT NOT NULL," +
        "  source TEXT DEFAULT ''," +
        "  trace_id TEXT DEFAULT ''," +
        "  timestamp INTEGER NOT NULL," +
        "  ttl_seconds INTEGER DEFAULT 604800" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS alert_rules (" +
        "  id INTEGER PRIMARY KEY," +
        "  team_id INTEGER NOT NULL," +
        "  service_id INTEGER DEFAULT 0," +
        "  name TEXT NOT NULL," +
        "  condition_metric TEXT NOT NULL," +
        "  condition_op TEXT NOT NULL," +
        "  condition_value REAL NOT NULL," +
        "  duration_sec INTEGER DEFAULT 60," +
        "  severity TEXT DEFAULT 'warning'," +
        "  channel TEXT DEFAULT 'webhook'," +
        "  channel_config TEXT DEFAULT '{}'," +
        "  muted_until INTEGER DEFAULT 0," +
        "  created_at INTEGER NOT NULL," +
        "  updated_at INTEGER NOT NULL" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS incidents (" +
        "  id INTEGER PRIMARY KEY," +
        "  alert_rule_id INTEGER NOT NULL," +
        "  status TEXT DEFAULT 'open'," +
        "  triggered_at INTEGER NOT NULL," +
        "  acknowledged_at INTEGER DEFAULT 0," +
        "  resolved_at INTEGER DEFAULT 0," +
        "  details TEXT DEFAULT ''" +
        ")"
    )
    db_execute(
        "CREATE TABLE IF NOT EXISTS embeddings (" +
        "  id INTEGER PRIMARY KEY," +
        "  source_type TEXT NOT NULL," +
        "  source_id INTEGER NOT NULL," +
        "  vector_data TEXT NOT NULL," +
        "  dimension INTEGER NOT NULL," +
        "  created_at INTEGER NOT NULL" +
        ")"
    )
}

# DB 정리
F teardown_test_db() {
    db_execute("DELETE FROM embeddings")
    db_execute("DELETE FROM incidents")
    db_execute("DELETE FROM alert_rules")
    db_execute("DELETE FROM logs")
    db_execute("DELETE FROM metrics")
    db_execute("DELETE FROM service_graph_edges")
    db_execute("DELETE FROM service_graph_nodes")
    db_execute("DELETE FROM service_dependencies")
    db_execute("DELETE FROM services")
    db_execute("DELETE FROM sessions")
    db_execute("DELETE FROM users")
    db_execute("DELETE FROM teams")
    db_close()
}

# 간단한 assert 함수
F assert(condition: bool, message: str) {
    I !condition {
        panic("ASSERTION FAILED: " + message)
    }
    println("  PASS: " + message)
}

F assert_eq_str(actual: str, expected: str, message: str) {
    I actual != expected {
        panic("ASSERTION FAILED: " + message + " | expected='" + expected + "' got='" + actual + "'")
    }
    println("  PASS: " + message)
}

F assert_ne_str(actual: str, unexpected: str, message: str) {
    I actual == unexpected {
        panic("ASSERTION FAILED: " + message + " | got unexpected value='" + actual + "'")
    }
    println("  PASS: " + message)
}

# 응답에서 status 코드 추출
F get_status(resp: str) -> str {
    json_get(resp, "status")
}

# 응답 body에서 필드 추출
F get_body_field(resp: str, field: str) -> str {
    body := json_get(resp, "body")
    json_get(body, field)
}

# Authorization 헤더 빌드
F make_auth_header(token: str) -> str {
    "Authorization: Bearer " + token
}

# ============================================================================
# TEST 1: 인증 흐름 — 가입 → 로그인 → 토큰 발급 → 보호 API 접근
# ============================================================================

F test_auth_flow() {
    println("[test_auth_flow] start")
    setup_test_db()

    # 1. 회원 가입
    register_body := "{\"email\":\"alice@test.com\",\"password\":\"password123\",\"name\":\"Alice\"}"
    reg_resp := handle_register(register_body)
    assert_eq_str(get_status(reg_resp), "201", "register returns 201")

    reg_body := json_get(reg_resp, "body")
    access_token := json_get(reg_body, "access_token")
    refresh_token_val := json_get(reg_body, "refresh_token")
    assert(str_len(access_token) > 0, "register response contains access_token")
    assert(str_len(refresh_token_val) > 0, "register response contains refresh_token")

    # 2. 로그인
    login_body := "{\"email\":\"alice@test.com\",\"password\":\"password123\"}"
    login_resp := handle_login(login_body)
    assert_eq_str(get_status(login_resp), "200", "login returns 200")

    login_resp_body := json_get(login_resp, "body")
    login_token := json_get(login_resp_body, "access_token")
    login_refresh := json_get(login_resp_body, "refresh_token")
    assert(str_len(login_token) > 0, "login response contains access_token")
    assert(str_len(login_refresh) > 0, "login response contains refresh_token")

    # 3. 잘못된 비밀번호로 로그인 시도
    bad_login := "{\"email\":\"alice@test.com\",\"password\":\"wrongpassword\"}"
    bad_resp := handle_login(bad_login)
    assert_eq_str(get_status(bad_resp), "401", "login with wrong password returns 401")

    # 4. 보호 API 접근 — /auth/me
    auth_headers := make_auth_header(login_token)
    me_resp := handle_me(auth_headers)
    assert_eq_str(get_status(me_resp), "200", "GET /auth/me with valid token returns 200")
    me_user := json_get(json_get(me_resp, "body"), "user")
    assert(str_len(me_user) > 0, "GET /auth/me returns user object")
    assert_eq_str(json_get(me_user, "email"), "alice@test.com", "user email matches")

    # 5. 토큰 없이 보호 API 접근
    no_auth_resp := handle_me("")
    assert_eq_str(get_status(no_auth_resp), "401", "GET /auth/me without token returns 401")

    # 6. refresh token으로 access token 갱신
    refresh_body := "{\"refresh_token\":\"" + login_refresh + "\"}"
    refresh_resp := handle_refresh(refresh_body)
    assert_eq_str(get_status(refresh_resp), "200", "token refresh returns 200")
    new_token := json_get(json_get(refresh_resp, "body"), "access_token")
    assert(str_len(new_token) > 0, "refresh response contains new access_token")

    # 7. 로그아웃
    logout_body := "{\"refresh_token\":\"" + login_refresh + "\"}"
    logout_resp := handle_logout(logout_body)
    assert_eq_str(get_status(logout_resp), "200", "logout returns 200")

    teardown_test_db()
    println("[test_auth_flow] PASSED")
}

# ============================================================================
# TEST 2: 서비스 CRUD 흐름 — 생성 → 조회 → 수정 → 삭제
# ============================================================================

F test_service_crud() {
    println("[test_service_crud] start")
    setup_test_db()

    # admin 사용자 및 팀 설정
    now_sec := current_time_ms() / 1000
    pw_hash := hash_password("adminpass")
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('TeamA', " + i64_to_str(now_sec) + ")"
    )
    team_row := db_query("SELECT id FROM teams WHERE name = 'TeamA' LIMIT 1")
    team_id := str_to_i64(json_get(team_row, "id"))

    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('admin@test.com', '" + pw_hash + "', 'Admin', 'admin', " +
        i64_to_str(team_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    user_row := db_query("SELECT id FROM users WHERE email = 'admin@test.com' LIMIT 1")
    user_id := str_to_i64(json_get(user_row, "id"))

    cfg := ServerConfig::default()
    token := create_access_token(user_id, "admin@test.com", "admin", cfg)
    headers := make_auth_header(token)

    # 1. 서비스 생성
    create_body := "{\"name\":\"API Service\",\"url\":\"http://api.example.com\"," +
        "\"health_endpoint\":\"/health\",\"check_interval_sec\":30,\"tags\":\"backend,api\"}"
    create_resp := handle_create_service(headers, create_body)
    assert_eq_str(get_status(create_resp), "201", "create service returns 201")
    created_svc := json_get(json_get(create_resp, "body"), "service")
    service_id := str_to_i64(json_get(created_svc, "id"))
    assert(service_id > 0, "created service has valid id")
    assert_eq_str(json_get(created_svc, "name"), "API Service", "created service name matches")

    # 2. 서비스 조회
    get_resp := handle_get_service(headers, service_id)
    assert_eq_str(get_status(get_resp), "200", "get service returns 200")
    fetched_svc := json_get(json_get(get_resp, "body"), "service")
    assert_eq_str(json_get(fetched_svc, "name"), "API Service", "fetched service name matches")

    # 3. 존재하지 않는 서비스 조회
    not_found_resp := handle_get_service(headers, 9999)
    assert_eq_str(get_status(not_found_resp), "404", "get non-existent service returns 404")

    # 4. 서비스 수정
    update_body := "{\"name\":\"API Service v2\",\"check_interval_sec\":60}"
    update_resp := handle_update_service(headers, service_id, update_body)
    assert_eq_str(get_status(update_resp), "200", "update service returns 200")
    updated_svc := json_get(json_get(update_resp, "body"), "service")
    assert_eq_str(json_get(updated_svc, "name"), "API Service v2", "updated service name matches")

    # 5. 서비스 목록 조회
    list_resp := handle_list_services(headers, "page=1&limit=20")
    assert_eq_str(get_status(list_resp), "200", "list services returns 200")

    # 6. 서비스 삭제
    del_resp := handle_delete_service(headers, service_id)
    assert_eq_str(get_status(del_resp), "200", "delete service returns 200")

    # 7. 삭제된 서비스 조회 시 404
    after_del_resp := handle_get_service(headers, service_id)
    assert_eq_str(get_status(after_del_resp), "404", "get deleted service returns 404")

    teardown_test_db()
    println("[test_service_crud] PASSED")
}

# ============================================================================
# TEST 3: 메트릭 수집/조회 흐름 — push → aggregate → query
# ============================================================================

F test_metrics_flow() {
    println("[test_metrics_flow] start")
    setup_test_db()

    # 환경 설정: 사용자, 팀, 서비스
    now_sec := current_time_ms() / 1000
    pw_hash := hash_password("pass1234")
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('MetricTeam', " + i64_to_str(now_sec) + ")"
    )
    team_row := db_query("SELECT id FROM teams WHERE name = 'MetricTeam' LIMIT 1")
    team_id := str_to_i64(json_get(team_row, "id"))

    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('metrics_user@test.com', '" + pw_hash + "', 'MetricsUser', 'member', " +
        i64_to_str(team_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    user_row := db_query("SELECT id FROM users WHERE email = 'metrics_user@test.com' LIMIT 1")
    user_id := str_to_i64(json_get(user_row, "id"))

    db_execute(
        "INSERT INTO services (team_id, name, url, health_endpoint, check_interval_sec, status, tags, created_at, updated_at) " +
        "VALUES (" + i64_to_str(team_id) + ", 'MetricService', 'http://metrics.example.com', '/health', 60, 'up', 'backend', " +
        i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    svc_row := db_query("SELECT id FROM services WHERE name = 'MetricService' LIMIT 1")
    service_id := str_to_i64(json_get(svc_row, "id"))

    cfg := ServerConfig::default()
    token := create_access_token(user_id, "metrics_user@test.com", "member", cfg)
    headers := make_auth_header(token)

    # 1. 단일 메트릭 push
    push_body := "{\"service_id\":" + i64_to_str(service_id) +
        ",\"name\":\"cpu_usage\",\"value\":45.5}"
    push_resp := handle_push_metrics(headers, push_body)
    assert_eq_str(get_status(push_resp), "201", "push single metric returns 201")
    pushed_count := json_get(json_get(push_resp, "body"), "saved")
    assert_eq_str(pushed_count, "1", "single metric push saves 1 record")

    # 2. 배치 메트릭 push
    batch_body := "{\"service_id\":" + i64_to_str(service_id) +
        ",\"metrics\":[{\"name\":\"memory_usage\",\"value\":72.3},{\"name\":\"cpu_usage\",\"value\":60.0}]}"
    batch_resp := handle_push_metrics(headers, batch_body)
    assert_eq_str(get_status(batch_resp), "201", "push batch metrics returns 201")

    # 3. 메트릭 집계 조회
    agg_query := "service_id=" + i64_to_str(service_id) + "&name=cpu_usage"
    agg_resp := handle_aggregate_metrics(headers, agg_query)
    assert_eq_str(get_status(agg_resp), "200", "aggregate metrics returns 200")
    agg_body := json_get(agg_resp, "body")
    assert(str_len(json_get(agg_body, "avg")) > 0, "aggregate response contains avg")
    assert(str_len(json_get(agg_body, "count")) > 0, "aggregate response contains count")

    # 4. 서비스별 메트릭 시계열 조회
    svc_metrics_query := "name=cpu_usage&limit=50"
    svc_metrics_resp := handle_service_metrics(headers, service_id, svc_metrics_query)
    assert_eq_str(get_status(svc_metrics_resp), "200", "service metrics query returns 200")

    # 5. 서비스 미존재 시 404
    bad_push := "{\"service_id\":99999,\"name\":\"cpu_usage\",\"value\":10.0}"
    bad_push_resp := handle_push_metrics(headers, bad_push)
    assert_eq_str(get_status(bad_push_resp), "404", "push metric for non-existent service returns 404")

    teardown_test_db()
    println("[test_metrics_flow] PASSED")
}

# ============================================================================
# TEST 4: 로그 수집/검색 흐름 — ingest → search (BM25/BOOLEAN/PHRASE)
# ============================================================================

F test_logs_flow() {
    println("[test_logs_flow] start")
    setup_test_db()

    now_sec := current_time_ms() / 1000
    pw_hash := hash_password("logpass")
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('LogTeam', " + i64_to_str(now_sec) + ")"
    )
    team_row := db_query("SELECT id FROM teams WHERE name = 'LogTeam' LIMIT 1")
    team_id := str_to_i64(json_get(team_row, "id"))

    db_execute(
        "INSERT INTO users (email, password_hash, name, role, team_id, created_at, updated_at) " +
        "VALUES ('log_user@test.com', '" + pw_hash + "', 'LogUser', 'member', " +
        i64_to_str(team_id) + ", " + i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    user_row := db_query("SELECT id FROM users WHERE email = 'log_user@test.com' LIMIT 1")
    user_id := str_to_i64(json_get(user_row, "id"))

    db_execute(
        "INSERT INTO services (team_id, name, url, health_endpoint, check_interval_sec, status, tags, created_at, updated_at) " +
        "VALUES (" + i64_to_str(team_id) + ", 'LogService', 'http://log.example.com', '/health', 60, 'up', 'backend', " +
        i64_to_str(now_sec) + ", " + i64_to_str(now_sec) + ")"
    )
    svc_row := db_query("SELECT id FROM services WHERE name = 'LogService' LIMIT 1")
    service_id := str_to_i64(json_get(svc_row, "id"))

    cfg := ServerConfig::default()
    token := create_access_token(user_id, "log_user@test.com", "member", cfg)
    headers := make_auth_header(token)

    # 1. 단건 로그 수집
    ingest_body := "{\"service_id\":" + i64_to_str(service_id) +
        ",\"level\":\"ERROR\",\"message\":\"database connection timeout\",\"source\":\"db.vais\",\"trace_id\":\"trace-001\"}"
    ingest_resp := handle_ingest_logs(headers, ingest_body)
    assert_eq_str(get_status(ingest_resp), "201", "ingest single log returns 201")
    assert_eq_str(json_get(json_get(ingest_resp, "body"), "ingested"), "1", "single log ingested count is 1")

    # 2. 추가 로그 수집 (검색 테스트용)
    ingest_body2 := "{\"service_id\":" + i64_to_str(service_id) +
        ",\"level\":\"INFO\",\"message\":\"service started successfully\",\"source\":\"main.vais\",\"trace_id\":\"trace-002\"}"
    ingest_resp2 := handle_ingest_logs(headers, ingest_body2)
    assert_eq_str(get_status(ingest_resp2), "201", "ingest second log returns 201")

    # 3. 잘못된 log level로 수집 시도
    bad_level_body := "{\"service_id\":" + i64_to_str(service_id) +
        ",\"level\":\"INVALID\",\"message\":\"test\",\"source\":\"test.vais\"}"
    bad_level_resp := handle_ingest_logs(headers, bad_level_body)
    assert_eq_str(get_status(bad_level_resp), "400", "ingest with invalid level returns 400")

    # 4. BM25 풀텍스트 검색
    bm25_query := "q=database&mode=bm25&service_id=" + i64_to_str(service_id)
    bm25_resp := handle_search_logs(headers, bm25_query)
    assert_eq_str(get_status(bm25_resp), "200", "BM25 search returns 200")
    bm25_body := json_get(bm25_resp, "body")
    assert(str_len(json_get(bm25_body, "logs")) > 0, "BM25 search returns logs array")

    # 5. BOOLEAN 검색
    bool_query := "q=timeout&mode=boolean&service_id=" + i64_to_str(service_id)
    bool_resp := handle_search_logs(headers, bool_query)
    assert_eq_str(get_status(bool_resp), "200", "BOOLEAN search returns 200")

    # 6. PHRASE 검색
    phrase_query := "q=connection+timeout&mode=phrase&service_id=" + i64_to_str(service_id)
    phrase_resp := handle_search_logs(headers, phrase_query)
    assert_eq_str(get_status(phrase_resp), "200", "PHRASE search returns 200")

    # 7. 서비스별 로그 조회 (레벨 필터)
    svc_log_query := "level=ERROR&page=1&limit=20"
    svc_log_resp := handle_service_logs(headers, service_id, svc_log_query)
    assert_eq_str(get_status(svc_log_resp), "200", "service logs with level filter returns 200")

    # 8. 검색 쿼리 미제공 시 400
    no_q_resp := handle_search_logs(headers, "mode=bm25")
    assert_eq_str(get_status(no_q_resp), "400", "search without q returns 400")

    teardown_test_db()
    println("[test_logs_flow] PASSED")
}

# ============================================================================
# TEST 5: 알림 룰 → 인시던트 생성 흐름
# ============================================================================

F test_alert_incident_flow() {
    println("[test_alert_incident_flow] start")
    setup_test_db()

    now_sec := current_time_ms() / 1000
    pw_hash := hash_password("alertpass")
    db_execute(
        "INSERT INTO teams (name, created_at) VALUES ('AlertTeam', " + i64_to_str(now_sec) + ")"
    )
    team_row := db_query("SELECT id FROM teams WHERE name = 'AlertTeam' LIMIT 1")
