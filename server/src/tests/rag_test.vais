
# ============================================================================
# RAG 단위 테스트
# ============================================================================

# 간단한 assert 함수 (rag_test 전용 — integration_test와 동일 패턴)
F assert(condition: bool, message: str) {
    I !condition {
        panic("ASSERTION FAILED: " + message)
    }
    println("  PASS: " + message)
}

F assert_eq_str(actual: str, expected: str, message: str) {
    I actual != expected {
        panic("ASSERTION FAILED: " + message + " | expected='" + expected + "' got='" + actual + "'")
    }
    println("  PASS: " + message)
}

# ============================================================================
# TEST: chunk_text — 빈 텍스트
# ============================================================================

F test_chunk_text_empty() {
    println("[test_chunk_text_empty] start")

    cfg := default_chunk_config()
    chunks := chunk_text("", &cfg)

    # 빈 텍스트 → 청크 없음
    assert(count_json_array(chunks) == 0, "empty text should produce 0 chunks")

    println("[test_chunk_text_empty] PASSED")
}

# ============================================================================
# TEST: chunk_text — 짧은 텍스트 (청킹 불필요)
# ============================================================================

F test_chunk_text_short() {
    println("[test_chunk_text_short] start")

    cfg := default_chunk_config()  # chunk_size=512

    # 512자 미만의 짧은 텍스트 → 단 1개 청크
    short_text := "Hello, this is a short monitoring log entry."
    chunks := chunk_text(short_text, &cfg)

    assert(count_json_array(chunks) == 1, "short text (< chunk_size) should produce exactly 1 chunk")

    # 청크 내용이 원본 텍스트와 동일 (trim 적용)
    assert_eq_str(json_get(chunks, "0"), "Hello, this is a short monitoring log entry.", "single chunk content matches original text")

    println("[test_chunk_text_short] PASSED")
}

# ============================================================================
# TEST: chunk_text — 긴 텍스트 (다수 청크 생성)
# ============================================================================

F test_chunk_text_long() {
    println("[test_chunk_text_long] start")

    # 작은 chunk_size 설정으로 강제 분할
    cfg := ChunkConfig {
        chunk_size: 50,
        overlap: 10,
        separator: " ",
    }

    # 50자를 훨씬 넘는 긴 텍스트
    long_text := "alpha beta gamma delta epsilon zeta eta theta iota kappa lambda mu nu xi omicron pi rho sigma tau upsilon"
    chunks := chunk_text(long_text, &cfg)

    # 여러 청크가 생성되어야 함
    assert(count_json_array(chunks) > 1, "long text should produce more than 1 chunk")

    # 각 청크는 비어 있지 않아야 함
    assert(str_len(json_get(chunks, "0")) > 0, "first chunk should not be empty")
    assert(str_len(json_get(chunks, "1")) > 0, "second chunk should not be empty")

    println("[test_chunk_text_long] PASSED")
}

# ============================================================================
# TEST: chunk_text — 커스텀 설정 (chunk_size=100, overlap=20)
# ============================================================================

F test_chunk_text_custom_config() {
    println("[test_chunk_text_custom_config] start")

    cfg := ChunkConfig {
        chunk_size: 100,
        overlap: 20,
        separator: " ",
    }

    # 정확히 100자를 넘는 텍스트
    text := "The quick brown fox jumps over the lazy dog. " +
        "Pack my box with five dozen liquor jugs. " +
        "How valiantly did she write those wonderful extra logs today!"

    chunks := chunk_text(text, &cfg)

    # 최소 1개 이상의 청크 생성
    assert(count_json_array(chunks) >= 1, "text should produce at least 1 chunk with custom config")

    println("[test_chunk_text_custom_config] PASSED")
}

# ============================================================================
# TEST: chunk_text — 유효하지 않은 chunk_size (< 1) → 기본값 512 사용
# ============================================================================

F test_chunk_text_invalid_chunk_size() {
    println("[test_chunk_text_invalid_chunk_size] start")

    cfg := ChunkConfig {
        chunk_size: 0,   # 유효하지 않음 → 내부에서 512로 보정
        overlap: 0,
        separator: " ",
    }

    short_text := "just a short text"
    chunks := chunk_text(short_text, &cfg)

    # chunk_size=0이 512로 보정되므로 짧은 텍스트는 1개 청크
    assert(count_json_array(chunks) == 1, "invalid chunk_size=0 falls back to 512, short text = 1 chunk")

    println("[test_chunk_text_invalid_chunk_size] PASSED")
}

# ============================================================================
# TEST: rrf_score — Reciprocal Rank Fusion 점수 계산
# ============================================================================

F test_rrf_score_basic() {
    println("[test_rrf_score_basic] start")

    # rrf_score(rank, k) = 1 / (k + rank)
    # rank=1, k=60 → 1/61 ≈ 0.01639
    score1 := rrf_score(1, 60)
    assert(score1 > 0.016, "rrf_score(1, 60) should be > 0.016")
    assert(score1 < 0.017, "rrf_score(1, 60) should be < 0.017")

    # rank=2, k=60 → 1/62 ≈ 0.01613
    score2 := rrf_score(2, 60)
    assert(score2 > 0.016, "rrf_score(2, 60) should be > 0.016")
    assert(score2 < 0.0162, "rrf_score(2, 60) should be < 0.0162")

    # 높은 순위(낮은 rank 숫자)가 더 높은 점수를 가져야 함
    assert(score1 > score2, "rank 1 should have higher rrf_score than rank 2")

    println("[test_rrf_score_basic] PASSED")
}

F test_rrf_score_rank_ordering() {
    println("[test_rrf_score_rank_ordering] start")

    # rank가 커질수록 점수가 감소하는지 검증
    score_r1 := rrf_score(1, 60)
    score_r5 := rrf_score(5, 60)
    score_r10 := rrf_score(10, 60)

    assert(score_r1 > score_r5, "rank 1 score should be greater than rank 5 score")
    assert(score_r5 > score_r10, "rank 5 score should be greater than rank 10 score")

    println("[test_rrf_score_rank_ordering] PASSED")
}

F test_rrf_score_invalid_k() {
    println("[test_rrf_score_invalid_k] start")

    # k < 1이면 기본값 60으로 보정
    score_with_invalid_k := rrf_score(1, 0)
    score_with_default_k := rrf_score(1, 60)

    # k=0을 k=60으로 보정했으므로 두 점수가 같아야 함
    assert(score_with_invalid_k == score_with_default_k, "k=0 should fall back to k=60")

    # 음수 k도 60으로 보정
    score_with_neg_k := rrf_score(1, -10)
    assert(score_with_neg_k == score_with_default_k, "k=-10 should fall back to k=60")

    println("[test_rrf_score_invalid_k] PASSED")
}

# ============================================================================
# TEST: chunk_count — 청크 수 예측
# ============================================================================

F test_chunk_count_empty() {
    println("[test_chunk_count_empty] start")

    cfg := default_chunk_config()
    count := chunk_count("", &cfg)

    assert(count == 0, "empty text should have chunk_count = 0")

    println("[test_chunk_count_empty] PASSED")
}

F test_chunk_count_short() {
    println("[test_chunk_count_short] start")

    cfg := default_chunk_config()  # chunk_size=512, overlap=64

    short_text := "short log message"
    count := chunk_count(short_text, &cfg)

    # 짧은 텍스트 → 1개 청크 예측
    assert(count >= 1, "short text should have at least 1 predicted chunk")

    println("[test_chunk_count_short] PASSED")
}

# ============================================================================
# 전체 RAG 테스트 실행
# ============================================================================

F run_rag_tests() {
    println("=== Vais Monitor RAG Unit Tests ===")

    test_chunk_text_empty()
    test_chunk_text_short()
    test_chunk_text_long()
    test_chunk_text_custom_config()
    test_chunk_text_invalid_chunk_size()

    test_rrf_score_basic()
    test_rrf_score_rank_ordering()
    test_rrf_score_invalid_k()

    test_chunk_count_empty()
    test_chunk_count_short()

    println("=== All RAG tests passed! ===")
}
